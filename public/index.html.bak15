function doVM(L) {
  showReach(
    '<div class="modal-head"><div class="modal-title">🎙 Voicemail Drop</div><button class="modal-close" onclick="closeReach()">✕</button></div>' +
    '<div class="modal-body">' +
    '<p style="color:var(--muted);font-size:13px;">Pre-recorded voicemail drop without ringing.</p>' +
    '<select id="vm-t" style="width:100%;background:var(--panel-2);border:1px solid var(--border);color:var(--text);padding:10px;border-radius:8px;font-size:13px;margin-bottom:12px;font-family:inherit;">' +
