        desc: "Re-engage past nos after life events or pay raises.",
        sequence: [
          { when: "Day 0", channel: "Email", subject: "Checking in", body: "Hey {{name}}, just checking in. Hope things are going well." },
          { when: "Day 14", channel: "SMS", body: "Hey {{name}}, 50% off first month new client special. Interested?" },
        ]},
      { id: uuid(), name: "Ghosted Reminder", trigger: "7 days no response", status: "paused",
        channels: ["sms"], steps: 2, stats: { sent: 0, opened: 0, replied: 0, booked: 0 },
        desc: "Soft re-engagement for consult no-shows.",
        sequence: [
          { when: "Day 0", channel: "SMS", body: "Hey {{name}}, lost track of you. Still interested?" },
          { when: "Day 4", channel: "SMS", body: "No worries if not — happy to keep your info on file." },
        ]},
    ];
    saveCampaigns();
  }
}
function loadGoal() {
  var v = localStorage.getItem(GOAL_KEY);
  monthlyGoal = v ? Number(v) : 0;
}

// ==========================================================
// FILTER STATE
// ==========================================================
var activeTab = "all";
var searchQ = "";
var sortBy = "";

// Built-in tabs (all except "all" can be hidden)
var TAB_DEFS = [
  { id: "all", label: "All Leads", icon: "⋯", locked: true },
  { id: "clients", label: "Active Clients", icon: "💼" },
  { id: "priority", label: "Priority", icon: "⭐" },
  { id: "tasks", label: "Tasks", icon: "📅" },
  { id: "campaigns", label: "Campaigns", icon: "🚀" },
  { id: "buckets", label: "Buckets", icon: "🎯" },
  { id: "sync", label: "Sync", icon: "🔄" },
  { id: "won", label: "Closed Won", icon: "✓" },
  { id: "remaining", label: "Pipeline", icon: "○" },
  { id: "notes", label: "With Notes", icon: "📝" }
];
var HIDDEN_TABS_KEY = "arcascend_hidden_tabs";
var hiddenTabs = [];
function loadHiddenTabs() {
  var raw = localStorage.getItem(HIDDEN_TABS_KEY);
  if (raw === null) {
    // First run: hide Pipeline by default (per user request)
    hiddenTabs = ["remaining"];
    localStorage.setItem(HIDDEN_TABS_KEY, JSON.stringify(hiddenTabs));
  } else {
    try { hiddenTabs = JSON.parse(raw) || []; } catch(e) { hiddenTabs = []; }
  }
}
function saveHiddenTabs() {
  localStorage.setItem(HIDDEN_TABS_KEY, JSON.stringify(hiddenTabs));
}
function applyTabVisibility() {
  TAB_DEFS.forEach(function(t){
    var el = document.querySelector('.tab[data-tab="' + t.id + '"]');
    if (!el) return;
    el.style.display = (hiddenTabs.indexOf(t.id) >= 0) ? "none" : "";
  });
  // If the active tab got hidden, fall back to All Leads
  if (hiddenTabs.indexOf(activeTab) >= 0) {
    document.querySelectorAll(".tab").forEach(function(x){ x.classList.remove("active"); });
    var allTab = document.querySelector('.tab[data-tab="all"]');
    if (allTab) allTab.classList.add("active");
    activeTab = "all";
  }
}
function openTabsModal() {
  var list = $("tabs-toggle-list");
  list.innerHTML = TAB_DEFS.map(function(t){
    var hidden = hiddenTabs.indexOf(t.id) >= 0;
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--panel-2);border:1px solid var(--border);border-radius:8px;margin-bottom:8px;">' +
      '<div style="font-size:14px;">' + t.icon + ' ' + t.label + (t.locked ? ' <span style="font-size:10px;color:var(--muted);">(home — always shown)</span>' : '') + '</div>' +
      (t.locked
        ? '<span style="font-size:11px;color:var(--muted);">Locked</span>'
        : '<label style="display:inline-flex;align-items:center;gap:6px;cursor:pointer;font-size:12px;">' +
            '<input type="checkbox" data-tabtoggle="' + t.id + '" ' + (hidden ? "" : "checked") + ' style="width:16px;height:16px;cursor:pointer;">' +
            (hidden ? '<span style="color:var(--muted);">Hidden</span>' : '<span style="color:var(--won);">Shown</span>') +
          '</label>') +
    '</div>';
  }).join("");
  list.querySelectorAll("[data-tabtoggle]").forEach(function(cb){
    cb.addEventListener("change", function(){
      var id = cb.dataset.tabtoggle;
      if (cb.checked) {
        hiddenTabs = hiddenTabs.filter(function(x){ return x !== id; });
      } else {
        if (hiddenTabs.indexOf(id) < 0) hiddenTabs.push(id);
      }
      saveHiddenTabs();
      applyTabVisibility();
      renderMain();
      openTabsModal(); // refresh labels
    });
  });
  $("tabs-modal").classList.add("show");
}
function closeTabsModal() { $("tabs-modal").classList.remove("show"); }
var F = {
  level: "", timeline: "", status: "", active: "",
  goal: "", why: "", availability: "",
  hastask: "", priority: "", notes: ""
};

// Parse a lead's profile date (handles MM/DD/YYYY, M/D/YY, ISO, timestamps)
function parseLeadDate(L) {
  var d = (L.date || "").trim();
  if (!d) return 0;
  var m = d.match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
  if (m) {
    var year = parseInt(m[3]);
    if (year < 100) year += 2000;
    return new Date(year, parseInt(m[1]) - 1, parseInt(m[2])).getTime();
  }
  var t = Date.parse(d);
  return isNaN(t) ? 0 : t;
}

function sortLeads(arr) {
  var a = arr.slice();
  if (sortBy === "name-az") {
    a.sort(function(x, y){ return (x.name||"").toLowerCase() < (y.name||"").toLowerCase() ? -1 : 1; });
  } else if (sortBy === "name-za") {
    a.sort(function(x, y){ return (x.name||"").toLowerCase() > (y.name||"").toLowerCase() ? -1 : 1; });
  } else if (sortBy === "date-new") {
    a.sort(function(x, y){ return parseLeadDate(y) - parseLeadDate(x); });
  } else if (sortBy === "date-old") {
    a.sort(function(x, y){
      var dx = parseLeadDate(x), dy = parseLeadDate(y);
      // Push undated leads to the end
      if (!dx) return 1; if (!dy) return -1;
      return dx - dy;
    });
  } else if (sortBy === "viewed") {
    a.sort(function(x, y){ return (y.lastViewed||0) - (x.lastViewed||0); });
  }
  return a;
}

// ==========================================================
// FILTERING
// ==========================================================
function filterLeads(arr) {
  return arr.filter(function(L){
    if (F.level && L.level !== F.level) return false;
    if (F.timeline && (L.timeline||"").indexOf(F.timeline) < 0) return false;
    if (F.status && L.status !== F.status) return false;
    if (F.active) {
      var a = L.billing && L.billing.active;
      if (F.active === "yes" && !a) return false;
      if (F.active === "no" && a) return false;
    }
    if (F.goal && (L.goal||"").toLowerCase().indexOf(F.goal.toLowerCase()) < 0) return false;
    if (F.why && (L.whyNow||"").toLowerCase().indexOf(F.why.toLowerCase()) < 0) return false;
    if (F.availability && (L.availability||"").toLowerCase().indexOf(F.availability.toLowerCase()) < 0) return false;
    if (F.hastask) {
      var h = openTaskCount(L) > 0;
      if (F.hastask === "yes" && !h) return false;
      if (F.hastask === "no" && h) return false;
    }
    if (F.priority) {
      if (F.priority === "yes" && !L.priority) return false;
      if (F.priority === "no" && L.priority) return false;
    }
    if (F.notes) {
      var has = !!(L.notes && L.notes.trim());
      if (F.notes === "yes" && !has) return false;
      if (F.notes === "no" && has) return false;
    }
    if (searchQ) {
      var q = searchQ.toLowerCase();
      var hay = (L.name+" "+L.phone+" "+L.goal+" "+L.notes+" "+L.outcomes+" "+L.whyNow+" "+(L.other||"")).toLowerCase();
      if (hay.indexOf(q) < 0) return false;
    }
    return true;
  });
}
function bucketFor(L) {
  var s = (L.status||"").toLowerCase();
  if (s.indexOf("won") >= 0) return "won";
  if (s.indexOf("lost") >= 0) return "lost";
  return "remaining";
}
function leadsInBucket(b) {
  return LEADS.filter(function(L){
    var r = b.rule || {};
    if (r.level && L.level !== r.level) return false;
    if (r.status && L.status !== r.status) return false;
    if (r.active === "yes" && !(L.billing && L.billing.active)) return false;
    if (r.active === "no" && (L.billing && L.billing.active)) return false;
    if (r.goal && (L.goal||"").toLowerCase().indexOf(r.goal.toLowerCase()) < 0) return false;
    if (r.why && (L.whyNow||"").toLowerCase().indexOf(r.why.toLowerCase()) < 0) return false;
    if (r.timeline && (L.timeline||"").indexOf(r.timeline) < 0) return false;
    return true;
  });
}

// ==========================================================
// CSV / EXCEL PARSING
// ==========================================================
function parseCSV(text) {
  var first = text.split(/\r?\n/)[0] || "";
  var delim = first.split("\t").length > first.split(",").length ? "\t" : ",";
  var rows = [], row = [], field = "", inQ = false;
  for (var i = 0; i < text.length; i++) {
    var c = text[i];
    if (inQ) {
      if (c === '"' && text[i+1] === '"') { field += '"'; i++; }
      else if (c === '"') inQ = false;
      else field += c;
    } else {
      if (c === '"') inQ = true;
      else if (c === delim) { row.push(field); field = ""; }
      else if (c === "\n" || c === "\r") {
        if (field !== "" || row.length) { row.push(field); rows.push(row); }
        row = []; field = "";
        if (c === "\r" && text[i+1] === "\n") i++;
      } else field += c;
    }
  }
  if (field !== "" || row.length) { row.push(field); rows.push(row); }
  return rows.filter(function(r){ return r.some(function(c){ return String(c).trim(); }); });
}

function rowToLead(headers, row) {
  var matched = {};
  function get() {
    for (var i = 0; i < arguments.length; i++) {
      var k = String(arguments[i]).toLowerCase();
      for (var j = 0; j < headers.length; j++) {
        if (matched[j]) continue;
        if (String(headers[j]).toLowerCase().indexOf(k) >= 0) {
          matched[j] = true;
          return row[j] ? String(row[j]).trim() : "";
        }
      }
    }
    return "";
  }

  // PHONE first (so "client phone" matches phone, not name)
  var phone = get("phone", "mobile number", "cell phone", "cell number");
  // Then NAME with broad synonyms — Client, Customer, Contact, etc.
  var name = get("full name", "first name", "client name", "customer name", "name", "client", "customer", "contact", "person", "lead", "member");
  // Status
  var statusRaw = get("deal outcome", "outcome", "status", "stage") || "New";
  // Other recognized fields
  var date = get("timestamp", "date joined", "joined", "signed up", "start date", "date");
  var goal = get("fitness goal", "goals", "goal", "objective");
  var level = get("fitness level", "level", "experience");
  var timeline = get("timeline", "duration", "time frame");
  var style = get("preferred training style", "training style", "style", "format");
  var injuries = get("injuries", "injur", "health", "medical");
  var availability = get("availability", "schedule");
  var whyNow = get("why is now", "why now", "invest in", "reason");
  var outcomes = get("specific outcomes", "outcomes", "results");
  var other = get("anything else", "support", "comments", "additional");
  var notes = get("consultation notes", "notes", "remarks");

  // FALLBACK: if no name was matched, use the first non-matched non-empty column
  if (!name) {
    for (var i = 0; i < row.length; i++) {
      if (!matched[i] && row[i] && String(row[i]).trim()) {
        name = String(row[i]).trim();
        matched[i] = true;
        break;
      }
    }
  }

  // Normalize status
  var status = statusRaw;
  var sl = String(status).toLowerCase();
  if (sl.indexOf("won") >= 0) status = "Closed Won";
  else if (sl.indexOf("lost") >= 0) status = "Closed Lost";
  else if (sl.indexOf("pending") >= 0) status = "Pending";
  else if (sl.indexOf("open") >= 0) status = "Open";

  var lead = {
    date: date,
    name: name,
    phone: phone,
    goal: goal,
    level: level,
    timeline: timeline,
    style: style,
    injuries: injuries,
    availability: availability,
    whyNow: whyNow,
    outcomes: outcomes,
    other: other,
    notes: notes,
    status: status
  };

  // Everything unmatched with content → notes
  var extras = [];
  for (var j = 0; j < headers.length; j++) {
    if (!matched[j] && row[j] && String(row[j]).trim()) {
      var label = String(headers[j] || "").trim();
      if (!label) label = "Column " + (j + 1);
      extras.push(label + ": " + String(row[j]).trim());
    }
  }
  if (extras.length) {
    var sep = lead.notes ? "\n\n--- Additional fields ---\n" : "";
    lead.notes = (lead.notes || "") + sep + extras.join("\n");
  }
  return lead;
}

function importRows(rows) {
  if (!rows || rows.length < 2) throw new Error("No data rows. Did you include the header row?");
  var headers = rows[0];
  var added = 0, updated = 0, skipped = 0;
  for (var i = 1; i < rows.length; i++) {
    var lead = rowToLead(headers, rows[i]);
    if (!lead.name) { skipped++; continue; }
    var key = leadKey(lead);
    var existing = LEADS.find(function(L){ return leadKey(L) === key; });
    if (existing) {
      ["goal","level","timeline","style","injuries","availability","whyNow","outcomes","other"].forEach(function(f){
        if (!existing[f] && lead[f]) existing[f] = lead[f];
      });
      if (!existing.notes && lead.notes) existing.notes = lead.notes;
      if ((!existing.status || existing.status === "New") && lead.status && lead.status !== "New") {
        existing.status = lead.status;
      }
      updated++;
    } else {
      LEADS.unshift(lead);
      added++;
    }
  }
  saveState();
  renderAll();
  return { added: added, updated: updated, skipped: skipped, total: rows.length - 1 };
}

function importCsvText(text) {
  return importRows(parseCSV(text));
}

function importExcelFile(file, callback) {
  if (typeof XLSX === "undefined") {
    callback(null, new Error("Excel library failed to load. Try saving as CSV instead."));
    return;
  }
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var data = new Uint8Array(e.target.result);
      var workbook = XLSX.read(data, { type: "array" });
      var first = workbook.SheetNames[0];
      var sheet = workbook.Sheets[first];
      var rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "" });
      // Filter empty rows
      rows = rows.filter(function(r){ return r.some(function(c){ return String(c).trim(); }); });
      callback(rows, null);
    } catch (err) { callback(null, err); }
  };
  reader.onerror = function() { callback(null, new Error("Could not read file.")); };
  reader.readAsArrayBuffer(file);
}

// ==========================================================
// RENDER: REVENUE BANNER + COUNTS
// ==========================================================
function renderRevenueBanner() {
  var rev = totalRevenue();
  var paid = totalPaid();
  var outstanding = rev - paid;
  var count = activeClients().length;
  var goalProgress = monthlyGoal > 0 ? Math.round((rev / monthlyGoal) * 100) : null;

  $("revenue-banner").innerHTML =
    '<div class="rev-stat projection">' +
      '<div class="rev-stat-label">Monthly Projection</div>' +
      '<div class="rev-stat-value accent">' + fmt$(rev) + '</div>' +
    '</div>' +
    '<div class="rev-stat highlight">' +
      '<div class="rev-stat-label">Paid So Far</div>' +
      '<div class="rev-stat-value won">' + fmt$(paid) + '</div>' +
    '</div>' +
    '<div class="rev-stat" style="' + (outstanding > 0 ? 'border-color:rgba(245,158,11,0.4);' : '') + '">' +
      '<div class="rev-stat-label">Outstanding</div>' +
      '<div class="rev-stat-value" style="color:' + (outstanding > 0 ? 'var(--open)' : 'var(--muted)') + ';">' + fmt$(outstanding) + '</div>' +
    '</div>' +
    '<div class="rev-stat">' +
      '<div class="rev-stat-label">Active Clients</div>' +
      '<div class="rev-stat-value">' + count + '</div>' +
    '</div>' +
    (goalProgress !== null ?
      '<div class="rev-stat" style="' + (goalProgress >= 100 ? 'border-color:rgba(34,197,94,0.5);' : '') + '">' +
        '<div class="rev-stat-label">Goal Progress</div>' +
        '<div class="rev-stat-value' + (goalProgress >= 100 ? ' won' : '') + '">' + goalProgress + '%</div>' +
      '</div>'
    : '');
}

function renderTabCounts() {
  $("c-all").textContent = LEADS.length;
  $("c-clients").textContent = activeClients().length;
  $("c-priority").textContent = LEADS.filter(function(L){ return L.priority; }).length;
  $("c-won").textContent = LEADS.filter(function(L){ return bucketFor(L) === "won"; }).length;
  $("c-remaining").textContent = LEADS.filter(function(L){ return bucketFor(L) === "remaining"; }).length;
  $("c-notes").textContent = LEADS.filter(function(L){ return L.notes && L.notes.trim(); }).length;
  var tasks = 0;
  LEADS.forEach(function(L){ tasks += openTaskCount(L); });
  $("c-tasks").textContent = tasks;
  $("c-campaigns").textContent = CAMPAIGNS.filter(function(c){ return c.status === "active"; }).length;
  $("c-buckets").textContent = BUCKETS.length;
  var syncN = (localStorage.getItem(SHEET_URL_KEY) ? 1 : 0) + (localStorage.getItem(AUTO_SYNC_KEY) === "1" ? 1 : 0);
  $("c-sync").textContent = syncN;
}

// ==========================================================
// LEAD CARD
// ==========================================================
function sessionProgressBar(L) {
  var b = L.billing || {};
  if (!b.active || !b.sessions) return '';
  var total = b.sessions || 0;
  var used = b.sessionsUsed || 0;
  var remaining = Math.max(0, total - used);
  var pct = total > 0 ? Math.min(100, Math.round((used / total) * 100)) : 0;
  var fillClass = pct >= 90 ? 'danger' : pct >= 70 ? 'warning' : '';
  var safeName = (L.name||'').replace(/"/g,'&quot;');
  return '<div class="session-progress">' +
    '<div class="session-progress-label">Sessions Used <span>' + used + ' / ' + total + '</span></div>' +
    '<div class="session-bar"><div class="session-bar-fill ' + fillClass + '" style="width:' + pct + '%"></div></div>' +
    '<div class="session-counter">' +
    '<button class="session-counter-btn" onclick="event.stopPropagation();adjustSessions(\'' + safeName + '\',-1)">−</button>' +
    '<div class="session-counter-num">' + remaining + '</div>' +
    '<button class="session-counter-btn" onclick="event.stopPropagation();adjustSessions(\'' + safeName + '\',1)">+</button>' +
    '</div>' +
    '<div class="session-remaining">' + remaining + ' session' + (remaining !== 1 ? 's' : '') + ' remaining</div>' +
    '</div>';
}

function adjustSessions(name, delta) {
  var L = LEADS.find(function(l) { return l.name === name; });
  if (!L || !L.billing) return;
  var current = L.billing.sessionsUsed || 0;
  var newVal = Math.max(0, Math.min(L.billing.sessions || 0, current + delta));
  if (newVal === current) return;
  L.billing.sessionsUsed = newVal;
  logActivity(L, 'note', delta > 0 ? '✅ Session completed (' + newVal + '/' + L.billing.sessions + ')' : '↩️ Session removed (' + newVal + '/' + L.billing.sessions + ')');
  saveState();
  renderAll();
}
function leadCard(L) {
  var b = ensureBilling(L);
  var sc = b.active ? "active-client" : statusClass(L.status);
  var cls = sc + (L.priority ? " priority" : "");
  var goalShort = (L.goal||"").split(",").slice(0,2).map(function(g){ return g.trim(); }).join(" · ");
  var safeName = (L.name||"").replace(/"/g,'&quot;');
  var taskCount = openTaskCount(L);
  var nt = nextOpenTask(L);
  var pipB = nt ? dueBucket(nt.dueDate) : "";
  var pipCls = pipB === "overdue" ? "overdue" : (pipB === "today" ? "today" : "");
  var pip = taskCount > 0 ? '<span class="task-pip ' + pipCls + '">' + taskCount + '</span>' : '';

  var statusBadge = b.active
    ? '<span class="badge active-client">💎 Active Client</span>'
    : '<span class="badge ' + statusClass(L.status) + '">' + (L.status || "New") + '</span>';

  var billingBlock = b.active ?
    '<div class="billing-mini">' +
      '<div class="billing-mini-stat"><div class="billing-mini-label">Sessions</div><div class="billing-mini-value sess">' + (b.sessions || 0) + '</div></div>' +
      '<div class="billing-mini-stat"><div class="billing-mini-label">Rate</div><div class="billing-mini-value">' + fmt$(b.rate || 0) + '</div></div>' +
      '<div class="billing-mini-stat"><div class="billing-mini-label">Total</div><div class="billing-mini-value total">' + fmt$(leadTotal(L)) + '</div></div>' +
    '</div>' : '';

  var nextBlock = nt ?
    '<div class="action-card" style="border-left-color:' + (pipB === "overdue" ? "var(--lost)" : pipB === "today" ? "var(--open)" : "var(--accent)") + ';">' +
      '<div class="action-label">📅 Next: ' + nt.type + (nt.dueDate ? ' · ' + formatTaskDate(nt.dueDate) : '') + '</div>' +
      (nt.note || '<em>No note</em>') +
    '</div>' : '';

  return '<div class="lead-card ' + cls + '" data-name="' + safeName + '">' +
    pip +
    '<div class="lead-header">' +
      '<div style="display:flex;gap:10px;align-items:flex-start;flex:1;min-width:0;">' +
        '<button class="star-btn ' + (L.priority ? "active" : "") + '" data-star="' + safeName + '">' + (L.priority ? "★" : "☆") + '</button>' +
        '<div style="min-width:0;">' +
          '<div class="lead-name">' + L.name + '</div>' +
          '<div class="lead-date">' + (L.date || "") + (L.phone ? " · " + L.phone : "") + '</div>' +
        '</div>' +
      '</div>' +
      statusBadge +
    '</div>' +
    '<div class="lead-body">' + (goalShort || '<em>No goals listed</em>') + '</div>' +
    nextBlock +
    '<div class="lead-meta">' +
      (L.level ? '<span class="meta-chip">' + L.level + '</span>' : '') +
      (L.timeline ? '<span class="meta-chip">' + L.timeline + '</span>' : '') +
      (b.active && b.package ? '<span class="meta-chip">' + b.package + '</span>' : '') +
      (b.active ? '<span class="meta-chip" style="' + (b.paid ? 'background:rgba(34,197,94,0.15);color:var(--won);' : 'background:rgba(245,158,11,0.15);color:var(--open);') + '">' + (b.paid ? '✓ Paid' : '○ Unpaid') + '</span>' : '') +
      (L.consultStatus ? '<span class="meta-chip" style="background:rgba(167,139,250,0.15);color:var(--purple);">' + consultIcon(L.consultStatus) + ' ' + L.consultStatus + '</span>' : '') +
    '</div>' +
   billingBlock +
sessionProgressBar(L) +
'<div class="quick-actions">' +
'<button class="qa-btn" data-qa="note" data-name="' + safeName + '">📝 Note</button>' +
'<button class="qa-btn" data-qa="task" data-name="' + safeName + '">✅ Task</button>' +
'<button class="qa-btn" data-qa="call" data-name="' + safeName + '">📞 Call</button>' +
'<button class="qa-btn" data-qa="status" data-name="' + safeName + '">🔄 Status</button>' +
'</div>' +
'</div>';
}

function consultIcon(s) {
  if (s === "Complete") return "✅";
  if (s === "Not Complete") return "⬜";
  if (s === "Reschedule") return "🔄";
  if (s === "Follow Up") return "📌";
  if (s === "No Show") return "🚫";
  return "";
}

function showQaPopup(action, L, btnEl) {
  var old = document.getElementById('qa-popup');
  if (old) old.remove();

  var popup = document.createElement('div');
  popup.className = 'qa-popup';
  popup.id = 'qa-popup';

  var rect = btnEl.getBoundingClientRect();
  popup.style.top = (rect.bottom + 8 + window.scrollY) + 'px';
  popup.style.left = Math.min(rect.left, window.innerWidth - 320) + 'px';

  if (action === 'note') {
    popup.innerHTML =
      '<div class="qa-popup-title">📝 Add Note — ' + L.name + '</div>' +
      '<textarea id="qa-input" placeholder="Enter note..."></textarea>' +
      '<div class="qa-popup-actions">' +
      '<button class="qa-cancel" onclick="document.getElementById(\'qa-popup\').remove()">Cancel</button>' +
      '<button class="qa-confirm" onclick="qaConfirmNote(\'' + L.name.replace(/'/g,"\\'") + '\')">Save Note</button>' +
      '</div>';
  } else if (action === 'call') {
    popup.innerHTML =
      '<div class="qa-popup-title">📞 Log Call — ' + L.name + '</div>' +
      '<textarea id="qa-input" placeholder="Call notes..."></textarea>' +
      '<div class="qa-popup-actions">' +
      '<button class="qa-cancel" onclick="document.getElementById(\'qa-popup\').remove()">Cancel</button>' +
      '<button class="qa-confirm" onclick="qaConfirmCall(\'' + L.name.replace(/'/g,"\\'") + '\')">Log Call</button>' +
      '</div>';
  } else if (action === 'task') {
    popup.innerHTML =
      '<div class="qa-popup-title">✅ Add Task — ' + L.name + '</div>' +
      '<input type="text" id="qa-task-text" placeholder="Task description..." />' +
      '<input type="date" id="qa-task-date" value="' + new Date().toISOString().slice(0,10) + '" />' +
      '<div class="qa-popup-actions">' +
      '<button class="qa-cancel" onclick="document.getElementById(\'qa-popup\').remove()">Cancel</button>' +
      '<button class="qa-confirm" onclick="qaConfirmTask(\'' + L.name.replace(/'/g,"\\'") + '\')">Add Task</button>' +
      '</div>';
  } else if (action === 'status') {
    var statuses = [
      { label: '🔵 New', value: 'New' },
      { label: '🟡 Open', value: 'Open' },
      { label: '🟠 Pending', value: 'Pending' },
      { label: '🟢 Closed Won', value: 'Closed Won' },
      { label: '🔴 Closed Lost', value: 'Closed Lost' }
    ];
    var current = L.status || 'New';
    popup.innerHTML =
      '<div class="qa-popup-title">🔄 Change Status — ' + L.name + '</div>' +
      statuses.map(function(s) {
        var isActive = s.value === current;
        return '<div class="qa-status-option" style="' + (isActive ? 'background:rgba(79,158,255,0.15);color:var(--accent);' : '') + '" onclick="qaConfirmStatus(\'' + L.name.replace(/'/g,"\\'") + '\',\'' + s.value + '\')">' +
          s.label + (isActive ? ' ✓' : '') +
        '</div>';
      }).join('') +
      '<button class="qa-cancel" style="width:100%;margin-top:4px;padding:8px;border-radius:8px;background:var(--panel-2);color:var(--muted);border:1px solid var(--border);font-size:12px;cursor:pointer;" onclick="document.getElementById(\'qa-popup\').remove()">Cancel</button>';
  }

  document.body.appendChild(popup);

  setTimeout(function() {
    document.addEventListener('click', function closePopup(e) {
      if (!popup.contains(e.target)) {
        popup.remove();
        document.removeEventListener('click', closePopup);
      }
    });
  }, 100);
}

function qaConfirmNote(name) {
  var note = document.getElementById('qa-input').value.trim();
  if (!note) return;
  var L = LEADS.find(function(l) { return l.name === name; });
  if (!L) return;
  L.notes = (L.notes ? L.notes + '\n' : '') + new Date().toLocaleDateString() + ': ' + note;
  logActivity(L, 'note', '📝 Note: ' + note);
  document.getElementById('qa-popup').remove();
  saveState(); renderAll();
}

function qaConfirmCall(name) {
  var note = document.getElementById('qa-input').value.trim() || 'Call logged';
  var L = LEADS.find(function(l) { return l.name === name; });
  if (!L) return;
  logActivity(L, 'call', '📞 ' + note);
  L.notes = (L.notes ? L.notes + '\n' : '') + new Date().toLocaleDateString() + ': 📞 ' + note;
  document.getElementById('qa-popup').remove();
  saveState(); renderAll();
}

function qaConfirmTask(name) {
  var text = document.getElementById('qa-task-text').value.trim();
  var date = document.getElementById('qa-task-date').value;
  if (!text) return;
  var L = LEADS.find(function(l) { return l.name === name; });
  if (!L) return;
  if (!L.tasks) L.tasks = [];
  L.tasks.push({ id: uuid(), type: 'Task', note: text, dueDate: date || '', completed: false });
 logActivity(L, 'note', '✅ Task added: ' + text + (date ? ' · Due ' + date : ''));
  document.getElementById('qa-popup').remove();
  saveState(); renderAll();
}

function qaConfirmStatus(name, status) {
  var L = LEADS.find(function(l) { return l.name === name; });
  if (!L) return;
var fromStatus = L.status;
L.status = status;
logEvent('status_changed', L.name, { from: fromStatus, to: status });
logActivity(L, 'note', '🔄 Status changed to: ' + status);
  document.getElementById('qa-popup').remove();
  saveState(); renderAll();
}
function wireCards() {
  document.querySelectorAll(".lead-card").forEach(function(c){
    c.addEventListener("click", function(){ openLead(c.dataset.name); });
  });
  document.querySelectorAll(".star-btn").forEach(function(b){
    b.addEventListener("click", function(e){
      e.stopPropagation();
      var L = LEADS.find(function(x){ return x.name === b.dataset.star; });
      if (!L) return;
      L.priority = !L.priority;
      saveState();
      renderAll();
    });
  });
   document.querySelectorAll('.lead-card').forEach(function(c) {
    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = 'lead-checkbox';
    cb.style.cssText = 'position:absolute;top:10px;right:10px;width:16px;height:16px;cursor:pointer;accent-color:#ef4444;z-index:10;display:none;';
    cb.addEventListener('click', function(e) {
      e.stopPropagation();
      var name = decodeURIComponent(c.dataset.name);
      if (cb.checked) {
        selectedLeads.add(name);
      } else {
        selectedLeads.delete(name);
      }
      updateBulkBar();
    });
    c.style.position = 'relative';
    c.appendChild(cb);
    c.addEventListener('mouseenter', function() { cb.style.display = 'block'; });
    c.addEventListener('mouseleave', function() { if (!cb.checked) cb.style.display = 'none'; });
    if (selectedLeads.has(decodeURIComponent(c.dataset.name))) {
      cb.checked = true;
      cb.style.display = 'block';
    }
  });
  document.querySelectorAll('.qa-btn').forEach(function(btn) {
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var name = this.dataset.name;
    var action = this.dataset.qa;
    var L = LEADS.find(function(l) { return l.name === name; });
    if (!L) return;
    showQaPopup(action, L, this);
  });
});
}

// ==========================================================
// CUSTOM TABS (pinned buckets)
// ==========================================================
function renderCustomTabs() {
  document.querySelectorAll(".tab.custom-tab,.tab-divider").forEach(function(e){ e.remove(); });
  var nav = $("tabs");
  var pinned = BUCKETS.filter(function(b){ return b.pinAsTab; });
  if (!pinned.length) return;
  var div = document.createElement("div");
  div.style.cssText = "width:1px;background:var(--border);margin:8px;";
  div.className = "tab-divider";
  nav.appendChild(div);
  pinned.forEach(function(b){
    var t = document.createElement("div");
    t.className = "tab custom-tab" + (activeTab === "custom-" + b.id ? " active" : "");
    t.dataset.tab = "custom-" + b.id;
    var cnt = leadsInBucket(b).length;
    t.innerHTML = '<span>' + b.icon + ' ' + b.name + '</span><span class="count">' + cnt + '</span><button class="tab-close" data-unpin="' + b.id + '">✕</button>';
    t.addEventListener("click", function(e){
      if (e.target.closest(".tab-close")) return;
      document.querySelectorAll(".tab").forEach(function(x){ x.classList.remove("active"); });
      t.classList.add("active");
      activeTab = "custom-" + b.id;
      renderMain();
    });
    t.querySelector(".tab-close").addEventListener("click", function(e){
      e.stopPropagation();
      b.pinAsTab = false;
      saveBuckets();
      if (activeTab === "custom-" + b.id) activeTab = "all";
      renderAll();
    });
    nav.appendChild(t);
  });
}

// ==========================================================
// MAIN RENDER
// ==========================================================
function emptyState(icon, msg) {
  return '<div class="empty"><div class="empty-icon">' + icon + '</div>' + msg + '</div>';
}

function welcomeState() {
  return '<div class="empty" style="padding:80px 20px;">' +
    '<div class="empty-icon">👋</div>' +
    '<div style="font-size:22px;color:var(--text);font-weight:700;margin-bottom:8px;">Welcome to ArcAscend</div>' +
    '<div style="margin-bottom:24px;font-size:14px;">Get your leads into the system to start tracking revenue.</div>' +
    '<div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">' +
      '<button onclick="goToTab(\'sync\')" class="btn" style="padding:14px 24px;font-size:14px;">🔄 Import from CSV / Excel / Sheets</button>' +
      '<button onclick="openAdd()" class="btn btn-ghost" style="padding:14px 24px;font-size:14px;">+ Add Lead Manually</button>' +
    '</div>' +
  '</div>';
}

function goToTab(name) {
  document.querySelectorAll(".tab").forEach(function(x){ x.classList.remove("active"); });
  var t = document.querySelector('.tab[data-tab="' + name + '"]');
  if (t) t.classList.add("active");
  activeTab = name;
  renderMain();
}

var leadView = localStorage.getItem('arcascend_lead_view') || 'list';

function renderKanban() {
  var main = $("main");
  var cols = [
    { key: 'New', color: '#60a5fa' },
    { key: 'Open', color: '#f59e0b' },
    { key: 'Pending', color: '#a78bfa' },
    { key: 'Closed Won', color: '#22c55e' },
    { key: 'Closed Lost', color: '#ef4444' }
  ];
  var pool = sortLeads(filterLeads(LEADS));
  var board = cols.map(function(c) {
    var inCol = pool.filter(function(l) { return (l.status || 'New') === c.key; });
    var cards = inCol.map(function(l) {
      var goal = l.goal || 'No goal listed';
      return '<div class="kanban-card" draggable="true" data-name="' + encodeURIComponent(l.name) + '" style="border-left-color:' + c.color + '" ' +
        'onclick="openLead(\'' + l.name.replace(/'/g, "\\'") + '\')">' +
        '<div class="kanban-card-name">' + l.name + '</div>' +
        '<div class="kanban-card-meta">' + goal + '</div></div>';
    }).join('');
    return '<div class="kanban-col" data-status="' + c.key + '">' +
      '<div class="kanban-col-head"><span class="kanban-col-title">' + c.key + '</span>' +
      '<span class="kanban-col-count">' + inCol.length + '</span></div>' + cards + '</div>';
  }).join('');

  main.innerHTML =
    '<div class="page-header"><div>' +
    '<div class="page-title">Pipeline Board</div>' +
    '<div class="page-subtitle">Drag leads between stages to update status</div>' +
    '</div>' + viewToggleHTML() + '</div>' +
    kanbanTipHTML() +'<div class="kanban-board">' + board + '</div>';

  wireKanban();
}
function kanbanTipHTML() {
  if (localStorage.getItem('arcascend_hide_kanban_tip') === '1') return '';
  return '<div id="kanban-tip" style="display:flex;align-items:center;justify-content:space-between;gap:12px;background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.3);border-radius:10px;padding:12px 16px;margin-bottom:16px;">' +
    '<div style="display:flex;align-items:center;gap:10px;">' +
    '<span style="font-size:18px;">💡</span>' +
    '<span style="font-size:13px;color:var(--text);">Tip: Drag any lead card between columns to instantly update their status. Changes save automatically.</span>' +
    '</div>' +
    '<div style="display:flex;align-items:center;gap:12px;white-space:nowrap;">' +
    '<label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);cursor:pointer;">' +
    '<input type="checkbox" onchange="dismissKanbanTip(this.checked)"> Don\'t show again</label>' +
    '<button onclick="document.getElementById(\'kanban-tip\').style.display=\'none\'" style="background:transparent;border:none;color:var(--muted);font-size:18px;cursor:pointer;line-height:1;">×</button>' +
    '</div></div>';
}

function dismissKanbanTip(checked) {
  if (checked) localStorage.setItem('arcascend_hide_kanban_tip', '1');
  else localStorage.removeItem('arcascend_hide_kanban_tip');
}

function viewToggleHTML() {
  return '<div class="view-toggle">' +
    '<button class="' + (leadView === 'list' ? 'active' : '') + '" onclick="setLeadView(\'list\')">List</button>' +
    '<button class="' + (leadView === 'board' ? 'active' : '') + '" onclick="setLeadView(\'board\')">Board</button>' +
    '</div>';
}

function setLeadView(v) {
  leadView = v;
  localStorage.setItem('arcascend_lead_view', v);
  renderMain();
}

function wireKanban() {
  var dragged = null;
  document.querySelectorAll('.kanban-card').forEach(function(card) {
    card.addEventListener('dragstart', function(e) {
      dragged = card;
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    card.addEventListener('dragend', function() {
      card.classList.remove('dragging');
      dragged = null;
    });
  });
  document.querySelectorAll('.kanban-col').forEach(function(col) {
    col.addEventListener('dragover', function(e) { e.preventDefault(); col.classList.add('drag-over'); });
    col.addEventListener('dragleave', function() { col.classList.remove('drag-over'); });
    col.addEventListener('drop', function(e) {
      e.preventDefault();
      col.classList.remove('drag-over');
      if (!dragged) return;
      var name = decodeURIComponent(dragged.dataset.name);
      var newStatus = col.dataset.status;
      var L = LEADS.find(function(x) { return x.name === name; });
      if (!L || L.status === newStatus) return;
      var oldStatus = L.status || 'New';
      L.status = newStatus;
      if (!L.activity) L.activity = [];
      L.activity.unshift({ type: 'status', text: 'Status changed from ' + oldStatus + ' to ' + newStatus, ts: Date.now() });
      saveState();
      renderKanban();
      renderTabCounts();
    });
  });
}

// ============== DYNAMIC PROFILE (Intake-driven) ==============
var __TRAINER_QUESTIONS = null;
var __TRAINER_QUESTIONS_LOADING = false;

async function loadTrainerQuestions() {
  if (__TRAINER_QUESTIONS || __TRAINER_QUESTIONS_LOADING) return __TRAINER_QUESTIONS;
  __TRAINER_QUESTIONS_LOADING = true;
  try {
    var uid = currentUser ? currentUser.id : localStorage.getItem('arcascend_user_id');
    var res = await fetch(SUPABASE_URL + '/rest/v1/trainer_settings?user_id=eq.' + uid + '&select=questions', {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY }
    });
    var rows = await res.json();
    var qs = (rows && rows[0] && rows[0].questions) ? rows[0].questions : null;
    if (!qs || !qs.length) {
      qs = [
        { id:'q_name', label:'Full Name', type:'text' },
        { id:'q_phone', label:'Phone Number', type:'tel' },
        { id:'q_email', label:'Email Address', type:'email' },
        { id:'q_goal', label:'What is your primary fitness goal?', type:'textarea' },
        { id:'q_level', label:'Training experience level', type:'select', options:['Beginner','Intermediate','Advanced'] },
        { id:'q_timeline', label:'What is your timeline?', type:'select', options:['ASAP','1-3 months','3-6 months','6+ months'] },
        { id:'q_style', label:'Preferred training style', type:'select', options:['1-on-1','Small group','Online','No preference'] },
        { id:'q_injuries', label:'Any injuries or limitations?', type:'textarea' },
        { id:'q_avail', label:'Availability (days/times)', type:'text' },
        { id:'q_whynow', label:'Why are you starting now?', type:'textarea' },
        { id:'q_outcomes', label:'Desired outcomes', type:'textarea' },
        { id:'q_other', label:'Anything else we should know?', type:'textarea' }
      ];
    }
    __TRAINER_QUESTIONS = qs;
  } catch(e) { console.warn('loadTrainerQuestions failed:', e); }
  __TRAINER_QUESTIONS_LOADING = false;
  return __TRAINER_QUESTIONS;
}

function escapeAttr(v){ return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escapeHtml(v){ return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// Special-case mapping: a few intake question ids correspond to existing top-level lead fields.
// Editing those should update the top-level field too (keeps search/filters/kanban working).
var INTAKE_TO_LEAD_FIELD = {
  q_name: 'name',
  q_phone: 'phone',
  q_email: 'email',
  q_goal: 'goal',
  q_level: 'level',
  q_timeline: 'timeline',
  q_style: 'style',
  q_avail: 'availability',
  q_injuries: 'injuries',
  q_whynow: 'whyNow',
  q_outcomes: 'outcomes',
  q_other: 'other'
};

function getAnswerValue(L, q) {
  // Prefer the answer saved by the intake form (keyed by question id).
  if (L[q.id] !== undefined && L[q.id] !== null && L[q.id] !== '') return L[q.id];
  // Fallback: legacy top-level field if mapped.
  var mapped = INTAKE_TO_LEAD_FIELD[q.id];
  if (mapped && L[mapped] !== undefined && L[mapped] !== null) return L[mapped];
  return '';
}

function renderDynamicProfile(L) {
  if (!__TRAINER_QUESTIONS) return '<div style="padding:10px;color:var(--text-muted)">Loading profile…</div>';
  var qs = __TRAINER_QUESTIONS;
  var html = '';
  html += '<div class="section-title" style="margin-top:20px;">\u270F\uFE0F PROFILE <span style="font-weight:normal;color:var(--text-muted);font-size:11px;text-transform:none;letter-spacing:0;">— click any field to edit, auto-saves on blur. Questions sync from your Forms tab.</span></div>';
  html += '<div class="field-grid">';
  qs.forEach(function(q){
    var val = getAnswerValue(L, q);
    var fullWidth = (q.type === 'textarea' || q.id === 'q_goal') ? ' style="grid-column:1/-1;"' : '';
    var input = '';
    var attrId = 'dyn-' + q.id;
    if (q.type === 'textarea') {
      input = '<textarea data-qid="' + escapeAttr(q.id) + '" id="' + attrId + '" rows="3">' + escapeHtml(val) + '</textarea>';
    } else if (q.type === 'select') {
      var optionList = (q.options||[]).slice();
      var hasMatch = optionList.some(function(o){ return String(o) === String(val); });
      // If saved value doesn't match any option (e.g. legacy free-text), include it so nothing is lost
      if (val && !hasMatch) optionList.push(val);
      var opts = '<option value="">—</option>' + optionList.map(function(o){
        return '<option value="' + escapeAttr(o) + '"' + (String(val)===String(o)?' selected':'') + '>' + escapeHtml(o) + '</option>';
      }).join('');
      input = '<select data-qid="' + escapeAttr(q.id) + '" id="' + attrId + '">' + opts + '</select>';
    } else if (q.type === 'multiselect') {
      var saved = String(val||'').split(/,\s*/).filter(Boolean);
      input = '<div>' + (q.options||[]).map(function(o){
        var chk = saved.indexOf(o) >= 0 ? ' checked' : '';
        return '<label class="opt" style="display:inline-flex;align-items:center;gap:6px;margin-right:10px;font-weight:400;font-size:13px;"><input type="checkbox" data-qid="' + escapeAttr(q.id) + '" data-qmulti="1" value="' + escapeAttr(o) + '"' + chk + '> ' + escapeHtml(o) + '</label>';
      }).join('') + '</div>';
    } else {
      input = '<input type="' + escapeAttr(q.type||'text') + '" data-qid="' + escapeAttr(q.id) + '" id="' + attrId + '" value="' + escapeAttr(val) + '">';
    }
    html += '<div class="form-field"' + fullWidth + '><label>' + escapeHtml(q.label||q.id) + '</label>' + input + '</div>';
  });
  html += '</div>';

  // Historical (orphaned) answers
  var currentIds = {};
  qs.forEach(function(q){ currentIds[q.id] = true; });
  var orphanKeys = Object.keys(L).filter(function(k){
    if (!k || k.indexOf('q_') !== 0) return false;
    if (currentIds[k]) return false;
    var v = L[k];
    return v !== '' && v != null;
  });
  if (orphanKeys.length){
    html += '<details style="margin-top:14px;"><summary style="cursor:pointer;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Historical Answers (' + orphanKeys.length + ')</summary>';
    html += '<div style="padding:10px 0;">';
    orphanKeys.forEach(function(k){
      html += '<div style="padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;">';
      html += '<div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;margin-bottom:3px;">' + escapeHtml(k) + '</div>';
      html += '<div>' + escapeHtml(L[k]) + '</div>';
      html += '</div>';
    });
    html += '</div></details>';
  }
  return html;
}

function wireDynamicProfile(L) {
  var mount = document.getElementById('dyn-profile-mount');
  if (!mount) return;
  // initial render (in case questions were already loaded)
  function paint(){
    mount.innerHTML = renderDynamicProfile(L);
    mount.querySelectorAll('[data-qid]').forEach(function(el){
      var qid = el.dataset.qid;
      var isMulti = el.dataset.qmulti === '1';
      var evt = (el.tagName === 'SELECT' || el.type === 'checkbox') ? 'change' : 'blur';
      el.addEventListener(evt, function(){
        var newVal;
        if (isMulti) {
          var boxes = mount.querySelectorAll('input[data-qid="' + qid + '"][data-qmulti="1"]');
          newVal = Array.from(boxes).filter(function(b){return b.checked;}).map(function(b){return b.value;}).join(', ');
        } else {
          newVal = el.value;
        }
        L[qid] = newVal;
        var mapped = INTAKE_TO_LEAD_FIELD[qid];
        if (mapped) L[mapped] = newVal;
        saveState();
        // re-render lists so name/phone/etc. update outside the modal
        if (typeof renderAll === 'function') renderAll();
      });
    });
  }
  if (__TRAINER_QUESTIONS) {
    paint();
  } else {
    loadTrainerQuestions().then(paint);
  }
}
// ============== /DYNAMIC PROFILE ==============



function saveAndCloseLead() {
  if (document.activeElement && document.activeElement.blur) document.activeElement.blur();
  try {
    if (typeof saveState === 'function') saveState();
    if (typeof saveToSupabase === 'function') saveToSupabase();
  } catch(e) { console.warn('saveAndCloseLead error:', e); }
  if (typeof closeLead === 'function') closeLead();
  if (typeof showToast === 'function') showToast('✅ Saved', 'success');
}

async function softRefresh() {
  var btn = document.getElementById('refresh-btn');
  var orig = btn ? btn.innerHTML : null;
  if (btn) { btn.disabled = true; btn.innerHTML = '↻ Refreshing...'; }
  try {
    if (typeof loadFromSupabase === 'function') await loadFromSupabase();
    if (typeof renderAll === 'function') renderAll();
    if (typeof showToast === 'function') showToast('✅ Refreshed', 'success');
  } catch(e) {
    console.warn('softRefresh error:', e);
    if (typeof showToast === 'function') showToast('Refresh failed', 'error');
  }
  if (btn) { btn.disabled = false; btn.innerHTML = orig || '↻ Refresh'; }
}

function renderMain() {
  var main = $("main");
  if (activeTab === "forms") {
    window.scrollTo(0,0);
    main.innerHTML = "";
    main.style.display = "none";
    var tb = document.querySelector(".toolbar"); if(tb) tb.style.display = "none";
    var fp = document.getElementById("tab-forms"); if(fp) fp.style.display = "block";
    formsInit();
    return;
  }
  main.style.display = "";
  var tb2 = document.querySelector(".toolbar"); if(tb2) tb2.style.display = "";
  var fp2 = document.getElementById("tab-forms"); if(fp2) fp2.style.display = "none";

  if (activeTab && activeTab.indexOf("custom-") === 0) {
    var bid = activeTab.slice("custom-".length);
    var b = BUCKETS.find(function(x){ return x.id === bid; });
    if (!b) { activeTab = "all"; return renderMain(); }
    var leads = sortLeads(filterLeads(leadsInBucket(b)));
    main.innerHTML =
      (leads.length ? '<div class="lead-grid">' + leads.map(leadCard).join("") + '</div>' : emptyState("📋", "No leads match."));
    wireCards();
    return;
  }
    

  if (activeTab === "clients") { renderClientsTab(); return; }
  if (activeTab === "tasks") { renderTasksTab(); return; }
if (activeTab === "active" && typeof renderActiveClientsBoard === "function") { renderActiveClientsBoard(); return; }
if (activeTab === "calendar") { renderCalendarTab(); return; }
  if (activeTab === "campaigns") { renderCampaignsTab(); return; }
  if (activeTab === "buckets") { renderBucketsTab(); return; }
  if (activeTab === "sync") { renderSyncTab(); return; }
  if (activeTab === "forms") { document.querySelectorAll(".tab-panel").forEach(function(p){p.style.display="none";}); var fp=document.getElementById("tab-forms"); if(fp)fp.style.display="block"; formsInit(); return; }

  // Standard list tabs
  var pool = LEADS;
  if (activeTab === "won") pool = LEADS.filter(function(L){ return bucketFor(L) === "won"; });
  else if (activeTab === "remaining") pool = LEADS.filter(function(L){ return bucketFor(L) === "remaining"; });
  else if (activeTab === "priority") pool = LEADS.filter(function(L){ return L.priority; });
  else if (activeTab === "notes") pool = LEADS.filter(function(L){ return L.notes && L.notes.trim(); });

  var leads = sortLeads(filterLeads(pool));

  if (LEADS.length === 0 && activeTab === "all") {
    main.innerHTML = welcomeState();
    return;
  }

  if (activeTab === "all" && leadView === "board") { renderKanban(); return; }
  main.innerHTML = leads.length
    ? viewToggleWrap(leads)
    : viewToggleHTML() + emptyState("📋", "No leads match the current filters.");
  wireCards();
}
function viewToggleWrap(leads) {
  return '<div class="page-header"><div></div>' + viewToggleHTML() + '</div>' +
    '<div class="lead-grid">' + leads.map(leadCard).join("") + '</div>';
}

// ==========================================================
// ACTIVE CLIENTS TAB
// ==========================================================
function renderClientsTab() {
  var main = $("main");
  var clients = sortLeads(filterLeads(activeClients()));
  var notSetUp = LEADS.filter(function(L){
    return (L.status || "").toLowerCase().indexOf("won") >= 0 && !(L.billing && L.billing.active);
  });

  var totalRev = 0, totalSess = 0, paidRev = 0, paidCount = 0;
  clients.forEach(function(L){
    totalRev += leadTotal(L);
    totalSess += (L.billing.sessions || 0);
    if (L.billing.paid) { paidRev += leadTotal(L); paidCount++; }
  });
  var outstandingRev = totalRev - paidRev;
  var avg = clients.length ? Math.round(totalRev / clients.length) : 0;

  var grid = clients.map(leadCard).join("");
  var promoteGrid = notSetUp.length ? notSetUp.slice(0, 20).map(function(L){
    var safeName = L.name.replace(/"/g,'&quot;');
    return '<div class="lead-card open" data-name="' + safeName + '">' +
      '<div class="lead-header">' +
        '<div><div class="lead-name">' + L.name + '</div>' +
        '<div class="lead-date">' + (L.phone || "") + '</div></div>' +
        '<span class="badge open">Won · Not Set Up</span>' +
      '</div>' +
      '<div style="color:var(--muted);font-size:12px;margin-top:10px;">Add session count and rate to start tracking.</div>' +
      '<button class="btn" style="width:100%;margin-top:10px;font-size:12px;padding:8px;" data-setup="' + safeName + '">💼 Set Up as Client</button>' +
    '</div>';
  }).join("") : "";

  main.innerHTML =
    '<div class="page-header"><div>' +
      '<div class="page-title">💼 Active Clients</div>' +
      '<div class="page-subtitle">Live revenue tracking. Click any client to update billing.</div>' +
    '</div></div>' +

    // Hero revenue panel
    '<div style="background:linear-gradient(135deg,rgba(34,197,94,0.1),rgba(167,139,250,0.05));border:1px solid rgba(34,197,94,0.4);border-radius:14px;padding:24px;margin-bottom:24px;">' +
      '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:18px;">' +
        '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Monthly Projection</div>' +
          '<div style="font-size:36px;font-weight:800;color:var(--accent);">' + fmt$(totalRev) + '</div></div>' +
        '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Paid So Far</div>' +
          '<div style="font-size:36px;font-weight:800;color:var(--won);">' + fmt$(paidRev) + '</div>' +
          '<div style="font-size:11px;color:var(--muted);margin-top:2px;">' + paidCount + ' of ' + clients.length + ' clients paid</div></div>' +
        '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Outstanding</div>' +
          '<div style="font-size:36px;font-weight:800;color:' + (outstandingRev > 0 ? 'var(--open)' : 'var(--muted)') + ';">' + fmt$(outstandingRev) + '</div></div>' +
        '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Active Clients</div>' +
          '<div style="font-size:36px;font-weight:800;">' + clients.length + '</div></div>' +
        '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Sessions Sold</div>' +
          '<div style="font-size:36px;font-weight:800;color:var(--purple);">' + totalSess + '</div></div>' +
        (monthlyGoal > 0 ?
          '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Goal Progress</div>' +
            '<div style="font-size:36px;font-weight:800;color:' + (totalRev >= monthlyGoal ? 'var(--won)' : 'var(--warm)') + ';">' + Math.round((totalRev / monthlyGoal) * 100) + '%</div>' +
            '<div style="font-size:11px;color:var(--muted);margin-top:2px;">of ' + fmt$(monthlyGoal) + '</div></div>'
        : '') +
      '</div>' +
    '</div>' +

    (clients.length ? '<div style="font-size:14px;font-weight:600;margin-bottom:12px;">Active Clients (' + clients.length + ')</div><div class="lead-grid">' + grid + '</div>' : '') +
    (notSetUp.length ? '<div style="font-size:14px;font-weight:600;margin:24px 0 12px;">Closed Won · Ready to Set Up (' + notSetUp.length + ')</div><div class="lead-grid">' + promoteGrid + '</div>' : '') +
    (clients.length === 0 && notSetUp.length === 0 ?
      '<div class="empty"><div class="empty-icon">💼</div>' +
      '<div style="font-size:16px;color:var(--text);margin-bottom:8px;">No clients yet</div>' +
      'Close a deal (mark a lead as <b>Closed Won</b>), then open the lead and toggle <b>Active Client</b> in the Billing section to start tracking revenue.</div>'
    : '');

  wireCards();
  document.querySelectorAll("[data-setup]").forEach(function(b){
    b.addEventListener("click", function(e){
      e.stopPropagation();
      openLead(b.dataset.setup);
    });
  });
}

// ==========================================================
// TASKS TAB
// ==========================================================
function renderTasksTab() {
  var main = $("main");
  var allT = [];
  LEADS.forEach(function(L){
    leadTasks(L).forEach(function(t){ allT.push({ t: t, L: L }); });
  });
  var groups = { overdue: [], today: [], tomorrow: [], thisweek: [], upcoming: [], done: [] };
  allT.forEach(function(it){
    if (it.t.completed) groups.done.push(it);
    else groups[dueBucket(it.t.dueDate)].push(it);
  });
  Object.keys(groups).forEach(function(k){
    groups[k].sort(function(a,b){ return (a.t.dueDate||"") < (b.t.dueDate||"") ? -1 : 1; });
  });

  function tr(it) {
    var bb = dueBucket(it.t.dueDate);
    var cls = it.t.completed ? "done" : bb;
    var safeName = it.L.name.replace(/"/g,'&quot;');
    return '<div class="task-row ' + cls + '" data-task-lead="' + safeName + '">' +
      '<button class="task-check ' + (it.t.completed?"checked":"") + '" data-task-toggle="' + it.t.id + '" data-task-leadname="' + safeName + '">' + (it.t.completed?"✓":"") + '</button>' +
      '<div class="task-body"><div class="task-text"><b>' + it.t.type + '</b> · ' + it.L.name + (it.t.note?" — "+it.t.note:"") + '</div>' +
      '<div class="task-meta"><span class="task-due ' + bb + '">' + (it.t.dueDate?formatTaskDate(it.t.dueDate):"No date") + '</span>' +
      (it.L.phone?'<span>📞 '+it.L.phone+'</span>':'') + '<span>' + it.L.status + '</span></div></div>' +
    '</div>';
  }

  var total = groups.overdue.length + groups.today.length + groups.tomorrow.length + groups.thisweek.length + groups.upcoming.length;
  if (total === 0 && groups.done.length === 0) {
    main.innerHTML = emptyState("📅", "No tasks yet. Open any lead and use the Reach Out Tomorrow or Book Follow-up presets to schedule next steps.");
    return;
  }
  function sec(label, icon, arr) {
    if (!arr.length) return "";
    return '<div class="task-group-title">' + icon + ' ' + label + '<span class="task-group-count">' + arr.length + '</span></div>' + arr.map(tr).join("");
  }
  main.innerHTML =
    sec("Overdue", "🔴", groups.overdue) +
    sec("Today", "🟡", groups.today) +
    sec("Tomorrow", "🟢", groups.tomorrow) +
    sec("This Week", "📅", groups.thisweek) +
    sec("Upcoming", "📆", groups.upcoming) +
    (groups.done.length ? '<div class="task-group-title" style="margin-top:30px;color:var(--muted);">✓ Completed<span class="task-group-count">' + groups.done.length + '</span></div>' + groups.done.map(tr).join("") : "");

  main.querySelectorAll(".task-row").forEach(function(el){
    el.addEventListener("click", function(){ openLead(el.dataset.taskLead); });
  });
  main.querySelectorAll(".task-check").forEach(function(b){
    b.addEventListener("click", function(e){
      e.stopPropagation();
      var L = LEADS.find(function(x){ return x.name === b.dataset.taskLeadname; });
      if (!L) return;
      var t = leadTasks(L).find(function(x){ return x.id === b.dataset.taskToggle; });
      if (!t) return;
      t.completed = !t.completed;
      saveState(); renderAll();
    });
  });
}

// ==========================================================
// CAMPAIGNS TAB
// ==========================================================
function renderCampaignsTab() {
  var main = $("main");
  var cards = CAMPAIGNS.map(function(c){
    var hasEmail = c.channels.indexOf("email") >= 0;
    var hasSms = c.channels.indexOf("sms") >= 0;
    return '<div class="campaign-card ' + c.status + '" data-cid="' + c.id + '">' +
      '<div class="campaign-name">' + c.name + '</div>' +
      '<div class="campaign-trigger">⚡ ' + c.trigger + '</div>' +
      '<div class="campaign-channels">' +
        (hasSms ? '<span class="channel-pill sms">📱 SMS</span>' : '') +
        (hasEmail ? '<span class="channel-pill email">✉ Email</span>' : '') +
        '<span class="channel-pill">' + c.steps + ' steps</span>' +
      '</div>' +
      '<div class="campaign-stats">' +
        '<div><div class="cstat-label">Sent</div><div class="cstat-value">' + c.stats.sent + '</div></div>' +
        '<div><div class="cstat-label">Open</div><div class="cstat-value">' + (c.stats.sent ? Math.round(c.stats.opened/c.stats.sent*100) : 0) + '%</div></div>' +
        '<div><div class="cstat-label">Reply</div><div class="cstat-value">' + (c.stats.sent ? Math.round(c.stats.replied/c.stats.sent*100) : 0) + '%</div></div>' +
        '<div><div class="cstat-label">Booked</div><div class="cstat-value">' + c.stats.booked + '</div></div>' +
      '</div></div>';
  }).join("");
  main.innerHTML =
    '<div class="page-header"><div>' +
      '<div class="page-title">🚀 Campaigns <span class="demo-pill">Demo Preview</span></div>' +
      '<div class="page-subtitle">Automated sequences. Sending requires backend wiring (Twilio/SendGrid).</div>' +
    '</div></div>' +
    '<div class="campaign-grid">' + cards + '</div>';

  main.querySelectorAll(".campaign-card").forEach(function(el){
    el.addEventListener("click", function(){ openCampaign(el.dataset.cid); });
  });
}

function openCampaign(id) {
  var c = CAMPAIGNS.find(function(x){ return x.id === id; });
  if (!c) return;
  var steps = (c.sequence || []).map(function(s, i){
    var body = s.body.replace(/\{\{(\w+)\}\}/g, '<span style="background:rgba(79,158,255,0.15);color:var(--accent);padding:1px 6px;border-radius:4px;font-size:12px;">{{$1}}</span>');
    return '<div style="display:flex;gap:14px;padding:14px 0;border-left:2px solid var(--border);margin-left:16px;padding-left:20px;position:relative;">' +
      '<div style="position:absolute;left:-14px;top:14px;background:var(--panel);border:2px solid var(--accent);color:var(--accent);width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">' + (i+1) + '</div>' +
      '<div style="flex:1;"><div style="font-size:11px;color:var(--muted);text-transform:uppercase;margin-bottom:4px;">' + s.channel + ' · ' + s.when + (s.subject?' · Subject: <b style="color:var(--text);">'+s.subject+'</b>':'') + '</div>' +
      '<div style="background:var(--panel-2);border:1px solid var(--border);padding:12px;border-radius:8px;white-space:pre-wrap;font-size:13px;line-height:1.6;">' + body + '</div></div></div>';
  }).join("");

  $("campaign-content").innerHTML =
    '<div class="modal-head">' +
      '<div><div class="modal-title">' + c.name + '</div>' +
      '<div style="color:var(--muted);font-size:12px;margin-top:2px;">⚡ ' + c.trigger + '</div></div>' +
      '<button class="modal-close" onclick="closeCampaign()">✕</button>' +
    '</div>' +
    '<div class="modal-body">' +
      '<p style="color:var(--muted);font-size:13px;">' + c.desc + '</p>' +
      '<div class="section-title">Sequence (' + (c.sequence || []).length + ' steps)</div>' +
      steps +
    '</div>';
  $("campaign-modal").classList.add("show");
}
function closeCampaign() { $("campaign-modal").classList.remove("show"); }

// ==========================================================
// BUCKETS TAB
// ==========================================================
function renderBucketsTab() {
  var main = $("main");
  var cards = BUCKETS.map(function(b){
    var cnt = leadsInBucket(b).length;
    return '<div class="bucket-card" data-bid="' + b.id + '">' +
      '<div class="bucket-icon">' + b.icon + '</div>' +
      '<div class="bucket-name">' + b.name + '</div>' +
      '<div class="bucket-desc">' + (b.desc || "") + '</div>' +
      '<div class="bucket-count-row"><div>' +
        '<div class="bucket-count">' + cnt + '</div>' +
        '<div class="bucket-count-label">leads match</div>' +
      '</div><div class="bucket-actions">' +
        '<button class="bucket-action" data-pin="' + b.id + '">' + (b.pinAsTab?"📌 Pinned":"📌 Pin") + '</button>' +
        '<button class="bucket-action" data-editbk="' + b.id + '">Edit</button>' +
        '<button class="bucket-action delete" data-delbk="' + b.id + '">Del</button>' +
      '</div></div></div>';
  }).join("");
  main.innerHTML =
    '<div class="page-header"><div>' +
      '<div class="page-title">🎯 Lead Buckets</div>' +
      '<div class="page-subtitle">Filter the pipeline by any combination. Pin any bucket as a nav tab.</div>' +
    '</div><button class="btn" id="new-bk">+ Create Bucket</button></div>' +
    '<div class="bucket-grid">' + cards + '</div>';

  $("new-bk").addEventListener("click", function(){ openBk(); });
  main.querySelectorAll(".bucket-card").forEach(function(el){
    el.addEventListener("click", function(e){
      if (e.target.closest(".bucket-action")) return;
      activeTab = "custom-" + el.dataset.bid;
      renderAll();
    });
  });
  main.querySelectorAll("[data-editbk]").forEach(function(b){
    b.addEventListener("click", function(e){ e.stopPropagation(); openBk(b.dataset.editbk); });
  });
  main.querySelectorAll("[data-pin]").forEach(function(b){
    b.addEventListener("click", function(e){
      e.stopPropagation();
      var bk = BUCKETS.find(function(x){ return x.id === b.dataset.pin; });
      if (!bk) return;
      bk.pinAsTab = !bk.pinAsTab;
      saveBuckets(); renderAll();
    });
  });
  main.querySelectorAll("[data-delbk]").forEach(function(b){
    b.addEventListener("click", function(e){
      e.stopPropagation();
      if (!confirm("Delete this bucket?")) return;
      BUCKETS = BUCKETS.filter(function(x){ return x.id !== b.dataset.delbk; });
      saveBuckets(); renderAll();
    });
  });
}

// ==========================================================
// SYNC TAB
// ==========================================================
function renderSyncTab() {
  var main = $("main");
  var sheetUrl = localStorage.getItem(SHEET_URL_KEY) || "";
  var autoOn = localStorage.getItem(AUTO_SYNC_KEY) === "1";
  var pollInt = localStorage.getItem(POLL_INT_KEY) || "300";

  main.innerHTML =
    '<div class="page-header"><div>' +
      '<div class="page-title">🔄 Sync &amp; Import</div>' +
      '<div class="page-subtitle">Drop a CSV or Excel file, paste from a spreadsheet, or auto-sync from Google Sheets.</div>' +
    '</div></div>' +

    '<div class="drop-zone" id="drop-zone">' +
      '<div class="drop-zone-icon">📂</div>' +
      '<div class="drop-zone-title">Drag &amp; drop your CSV or Excel file here</div>' +
      '<div class="drop-zone-sub">or click to browse · accepts .csv, .xlsx, .xls, .tsv</div>' +
      '<input type="file" id="sync-file" accept=".csv,.xlsx,.xls,.tsv,.txt" style="display:none;">' +
    '</div>' +

    '<div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;">' +
      '<span class="service-pill" style="background:' + (sheetUrl?"rgba(34,197,94,0.12)":"rgba(245,158,11,0.12)") + ';color:' + (sheetUrl?"var(--won)":"var(--open)") + ';border-color:' + (sheetUrl?"rgba(34,197,94,0.3)":"rgba(245,158,11,0.3)") + ';padding:8px 14px;font-size:13px;">' +
        '📊 Google Sheets · ' + (sheetUrl ? (autoOn ? "Auto-syncing" : "Connected") : "Not connected") +
      '</span>' +
      '<span class="service-pill" style="background:rgba(34,197,94,0.12);color:var(--won);border-color:rgba(34,197,94,0.3);padding:8px 14px;font-size:13px;">📊 Excel (.xlsx) · Ready</span>' +
      '<span class="service-pill" style="background:rgba(167,139,250,0.12);color:var(--purple);border-color:rgba(167,139,250,0.3);padding:8px 14px;font-size:13px;">📝 Google Forms · Via Sheets</span>' +
    '</div>' +

    '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px;">' +

      // Paste card
      '<div style="background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:20px;border-left:4px solid var(--won);">' +
        '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
          '<div style="font-size:24px;">📋</div>' +
          '<div style="font-size:16px;font-weight:700;">Paste from Spreadsheet</div>' +
        '</div>' +
        '<div style="color:var(--muted);font-size:13px;line-height:1.5;margin-bottom:14px;">Copy from your Sheet (<code style="background:var(--panel-2);padding:1px 4px;border-radius:3px;">⌘/Ctrl+A</code>, then <code style="background:var(--panel-2);padding:1px 4px;border-radius:3px;">⌘/Ctrl+C</code>), paste below.</div>' +
        '<textarea id="sync-paste" placeholder="Paste here..." style="width:100%;background:var(--panel-2);border:1px solid var(--border);color:var(--text);padding:10px;border-radius:8px;font-size:12px;font-family:inherit;min-height:80px;outline:none;margin-bottom:10px;"></textarea>' +
        '<button class="btn" id="sync-paste-btn" style="width:100%;">📋 Import Pasted Data</button>' +
      '</div>' +

      // Live Sheets sync card
      '<div style="background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:20px;border-left:4px solid var(--accent);">' +
        '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
          '<div style="font-size:24px;">⚡</div>' +
          '<div style="font-size:16px;font-weight:700;">Live Google Sheets Sync</div>' +
        '</div>' +
        '<div style="color:var(--muted);font-size:13px;line-height:1.5;margin-bottom:14px;">Auto-poll your published-CSV URL. <i>Only works when hosted (Netlify), not from a local file.</i></div>' +
        '<input id="sync-url" placeholder="https://docs.google.com/spreadsheets/.../pub?output=csv" value="' + sheetUrl + '" style="width:100%;background:var(--panel-2);border:1px solid var(--border);color:var(--text);padding:9px 12px;border-radius:8px;font-size:12px;font-family:inherit;outline:none;margin-bottom:10px;">' +
        '<div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">' +
          '<button class="btn" id="sync-now">⟳ Sync Now</button>' +
          '<label style="display:inline-flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">' +
            '<input type="checkbox" id="sync-auto" ' + (autoOn?"checked":"") + ' style="width:16px;height:16px;cursor:pointer;">' +
            '<span>Auto every</span>' +
            '<select id="sync-int" style="background:var(--panel-2);border:1px solid var(--border);color:var(--text);padding:3px 6px;border-radius:6px;font-size:12px;">' +
              '<option value="60" ' + (pollInt==="60"?"selected":"") + '>1 min</option>' +
              '<option value="300" ' + (pollInt==="300"?"selected":"") + '>5 min</option>' +
              '<option value="900" ' + (pollInt==="900"?"selected":"") + '>15 min</option>' +
            '</select>' +
          '</label>' +
        '</div>' +
      '</div>' +

    '</div>' +

    '<div style="margin-top:24px;background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:20px;">' +
      '<div style="font-size:14px;font-weight:600;margin-bottom:12px;">📊 Sync Activity</div>' +
      '<div id="sync-status"><div style="color:var(--muted);font-size:13px;">Drop a file above, paste data, or set up live Google Sheets sync.</div></div>' +
    '</div>' +

    '<div style="margin-top:18px;background:rgba(79,158,255,0.06);border:1px solid rgba(79,158,255,0.3);border-radius:8px;padding:14px;font-size:12px;line-height:1.6;">' +
      '<b style="color:var(--accent);">💡 Only Name is required</b><br>' +
      'Drop a CSV or Excel with any columns — as long as there\'s a name, the lead imports. Phone, goal, level, timeline, etc. are all optional. Any column the importer doesn\'t recognize gets appended to that lead\'s Consultation Notes as <code>Column Name: value</code>. Auto-mapped fields:<br><br>' +
      '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:6px;font-size:11px;">' +
        '<div>🔒 <b>Full Name</b> (only required)</div>' +
        '<div>• Phone / Phone Number</div>' +
        '<div>• Timestamp / Date</div>' +
        '<div>• Fitness Goal / Goal</div>' +
        '<div>• Fitness Level / Level</div>' +
        '<div>• Timeline</div>' +
        '<div>• Training Style</div>' +
        '<div>• Injuries / Health</div>' +
        '<div>• Availability</div>' +
        '<div>• Why now</div>' +
        '<div>• Specific outcomes</div>' +
        '<div>• Consultation Notes</div>' +
        '<div>• Deal Outcome / Status</div>' +
      '</div>' +
    '</div>';

  // Wire it up
  var dz = $("drop-zone");
  var fi = $("sync-file");
  dz.addEventListener("click", function(){ fi.click(); });
  dz.addEventListener("dragover", function(e){ e.preventDefault(); dz.classList.add("dragover"); });
  dz.addEventListener("dragleave", function(){ dz.classList.remove("dragover"); });
  dz.addEventListener("drop", function(e){
    e.preventDefault();
    dz.classList.remove("dragover");
    if (e.dataTransfer.files && e.dataTransfer.files[0]) handleSyncFile(e.dataTransfer.files[0]);
  });
  fi.addEventListener("change", function(e){
    if (e.target.files[0]) handleSyncFile(e.target.files[0]);
    e.target.value = "";
  });
  $("sync-paste-btn").addEventListener("click", function(){
    var text = $("sync-paste").value.trim();
    if (!text) { syncStatus("Paste spreadsheet content first.", "error"); return; }
    handleSyncImport(text, "pasted data");
    $("sync-paste").value = "";
  });
  $("sync-now").addEventListener("click", function(){ urlSyncNow(false); });
  $("sync-auto").addEventListener("change", function(e){
    if (e.target.checked) {
      if (!$("sync-url").value.trim()) {
        syncStatus("Paste a Google Sheets URL first.", "error");
        e.target.checked = false;
        return;
      }
      startPolling();
      syncStatus("✓ Auto-sync ON · every " + ($("sync-int").value/60|0) + " min", "success");
    } else {
      stopPolling();
      syncStatus("Auto-sync OFF");
    }
    renderTabCounts();
  });
  $("sync-int").addEventListener("change", function(){
    if ($("sync-auto").checked) startPolling();
  });
}

function handleSyncFile(file) {
  var name = file.name.toLowerCase();
  if (name.endsWith(".xlsx") || name.endsWith(".xls")) {
    importExcelFile(file, function(rows, err){
      if (err) { syncStatus("Excel import failed: " + err.message, "error"); return; }
      try {
        var r = importRows(rows);
        afterSyncImport(r, file.name);
      } catch(e) { syncStatus("Import failed: " + e.message, "error"); }
    });
  } else {
    var reader = new FileReader();
    reader.onload = function(ev){ handleSyncImport(ev.target.result, file.name); };
    reader.onerror = function(){ syncStatus("Could not read file.", "error"); };
    reader.readAsText(file);
  }
}

function handleSyncImport(text, sourceLabel) {
  try {
    var r = importCsvText(text);
    afterSyncImport(r, sourceLabel);
  } catch(err) {
    syncStatus("Import failed: " + err.message, "error");
    showToast("Import failed: " + err.message, "error");
  }
}

function afterSyncImport(r, sourceLabel) {
  syncStatus(
    '<div style="font-size:14px;font-weight:600;color:var(--won);margin-bottom:8px;">✓ Imported ' + r.added + ' new lead' + (r.added===1?'':'s') + ' · ' + r.updated + ' updated' + (r.skipped ? ' · <span style="color:var(--warm);">' + r.skipped + ' skipped (no name)</span>' : '') + '</div>' +
    '<div style="font-size:12px;color:var(--muted);">Source: ' + sourceLabel + ' · Total leads now: ' + LEADS.length + '</div>',
    "success"
  );
  showToast("✓ " + r.added + " lead" + (r.added===1?"":"s") + " imported! Switching to All Leads...", "success");
  setTimeout(function(){ goToTab("all"); }, 800);
}

function syncStatus(msg, kind) {
  var color = kind === "success" ? "var(--won)" : kind === "error" ? "var(--lost)" : "var(--muted)";
  var el = $("sync-status");
  if (!el) return;
  el.innerHTML = '<div style="color:' + color + ';font-size:13px;padding:10px;background:var(--panel-2);border-radius:6px;border-left:3px solid ' + color + ';">' + msg + '</div>';
}

function showToast(msg, kind) {
  var existing = document.querySelector(".toast");
  if (existing) existing.remove();
  var t = document.createElement("div");
  t.className = "toast" + (kind === "error" ? " error" : "");
  t.innerHTML = '<span style="font-size:18px;">' + (kind==="error"?"⚠️":"✓") + '</span><span>' + msg + '</span>';
  document.body.appendChild(t);
  setTimeout(function(){
    t.style.opacity = "0";
    t.style.transition = "opacity 0.3s";
    setTimeout(function(){ t.remove(); }, 300);
  }, 4000);
}

var pollTimer = null;
function urlSyncNow(silent) {
  var url = $("sync-url").value.trim();
  if (!url) { if (!silent) syncStatus("Paste a Google Sheets URL first.", "error"); return; }
  localStorage.setItem(SHEET_URL_KEY, url);
  if (!silent) syncStatus("⏳ Fetching from Google Sheets...");
  fetch(url, { mode: "cors" })
    .then(function(resp){ if (!resp.ok) throw new Error("HTTP "+resp.status); return resp.text(); })
    .then(function(text){
      var r = importCsvText(text);
      var when = new Date().toLocaleTimeString();
      syncStatus("✓ Synced " + when + " — " + r.added + " new, " + r.updated + " updated.", "success");
      renderTabCounts();
    })
    .catch(function(err){
      if (silent) return;
      syncStatus("Sync failed: " + err.message + ". URL sync only works when the CRM is hosted (Netlify). Use file upload or paste locally.", "error");
    });
}
function startPolling() {
  if (pollTimer) clearInterval(pollTimer);
  var seconds = parseInt($("sync-int").value || "300");
  pollTimer = setInterval(function(){ urlSyncNow(true); }, seconds * 1000);
  localStorage.setItem(AUTO_SYNC_KEY, "1");
  localStorage.setItem(POLL_INT_KEY, String(seconds));
}
function stopPolling() {
  if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  localStorage.setItem(AUTO_SYNC_KEY, "0");
}

// ==========================================================
// LEAD MODAL
// ==========================================================
function renderActivityLog(L) {
  var acts = activityList(L);
  if (!acts.length) {
    return '<div class="activity-log"><div class="activity-log-title">Recent Activity</div>' +
      '<div style="color:var(--muted);font-size:12px;text-align:center;padding:8px 0;">No activity yet. Use the buttons above to log calls/texts/emails.</div></div>';
  }
  var rows = acts.slice(0, 6).map(function(a){
    var ico = a.kind === "call" ? "📞" : a.kind === "text" ? "💬" : a.kind === "email" ? "✉️" : a.kind === "video" ? "🎥" : "🎙";
    return '<div class="activity-row"><div class="activity-icon ' + a.kind + '">' + ico + '</div>' +
      '<div class="activity-body">' + a.summary + '</div>' +
      '<div class="activity-meta">' + timeAgo(a.at) + '</div></div>';
  }).join("");
  return '<div class="activity-log"><div class="activity-log-title">Recent Activity (' + acts.length + ')</div>' + rows + '</div>';
}

function renderTasksForLead(L) {
  var tasks = leadTasks(L);
  if (!tasks.length) return '<div style="color:var(--muted);font-size:13px;padding:8px 0;">No tasks scheduled yet — use the quick buttons below.</div>';
  var sorted = tasks.slice().sort(function(a, b){
    if (a.completed !== b.completed) return a.completed ? 1 : -1;
    return (a.dueDate||"") < (b.dueDate||"") ? -1 : 1;
  });
  return sorted.map(function(t){
    var bb = dueBucket(t.dueDate);
    var cls = t.completed ? "done" : bb;
    return '<div class="task-row ' + cls + '">' +
      '<button class="task-check ' + (t.completed?"checked":"") + '" data-mt="' + t.id + '">' + (t.completed?"✓":"") + '</button>' +
      '<div class="task-body"><div class="task-text"><b>' + t.type + '</b>' + (t.note?" — "+t.note:"") + '</div>' +
      '<div class="task-meta"><span class="task-due ' + bb + '">' + (t.dueDate?formatTaskDate(t.dueDate):"No date") + '</span></div></div>' +
      '<button data-md="' + t.id + '" style="background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:14px;">✕</button>' +
    '</div>';
  }).join("");
}

function openLead(name) {
  var L = LEADS.find(function(x){ return x.name === name; });
  if (!L) return;
  L.lastViewed = Date.now();
  saveState();
  var b = ensureBilling(L);
  var statuses = ["Closed Won","Open","Pending","Closed Lost","New"];
  var sb = statuses.map(function(s){ return '<button class="status-btn ' + (s===L.status?"active":"") + '" data-s="' + s + '">' + s + '</button>'; }).join("");

  $("modal-content").innerHTML =
    '<div class="modal-head">' +
      '<div style="display:flex;gap:12px;align-items:flex-start;">' +
        '<button class="star-btn ' + (L.priority?"active":"") + '" id="m-star">' + (L.priority?"★":"☆") + '</button>' +
        '<div>' +
          '<div class="modal-title">' + L.name + (b.active ? ' <span class="badge active-client" style="margin-left:6px;">💎 ACTIVE</span>' : '') + '</div>' +
          '<div style="color:var(--muted);font-size:12px;margin-top:4px;">' + (L.date||"") + (L.phone?" · "+L.phone:"") + '</div>' +
        '</div>' +
      '</div>' +
      '<button onclick="saveAndCloseLead()" style="background:var(--accent);color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:13px;font-weight:600;cursor:pointer;margin-right:8px;">💾 Save & Close</button><button class="modal-close" onclick="closeLead()">✕</button>' +
    '</div>' +
    '<div class="modal-body">' +

      '<div class="reachout-bar"><div class="section-title" style="margin:0;border:none;padding:0;">📞 Reach Out</div><span class="service-pill">RingDNA · Demo</span></div>' +
      '<div class="reach-actions">' +
        
        '<button class="reach-btn text" data-r="text"><div class="ricon">💬</div>Text</button>' +
        '<button class="reach-btn email" data-r="email"><div class="ricon">✉️</div>Email</button>' +
        
        
      '</div>' +
      renderActivityLog(L) +

      (L.priority ? '<div class="section-title">📌 Priority Note</div><textarea class="notes-edit" id="m-pnote">' + (L.priorityNote||"") + '</textarea>' : '') +

      '<div class="section-title">💰 Billing &amp; Sessions</div>' +
      '<div class="billing-box">' +
        '<div class="billing-toggle">' +
          '<input type="checkbox" id="b-active" ' + (b.active?"checked":"") + '>' +
          '<label for="b-active" style="font-weight:600;cursor:pointer;">Mark as Active Client (counts toward monthly revenue)</label>' +
        '</div>' +
        '<div class="billing-grid">' +
          '<div class="billing-field"><label>Sessions Purchased</label><input type="number" id="b-sessions" value="' + (b.sessions||0) + '" min="0"></div>' +
          '<div class="billing-field"><label>Session Price ($)</label><input type="number" id="b-rate" value="' + (b.rate||0) + '" min="0"></div>' +
          '<div class="billing-field"><label>Package</label>' +
            '<select id="b-package">' +
              '<option value="" ' + (!b.package?"selected":"") + '>—</option>' +
              '<option ' + (b.package==="1x/week"?"selected":"") + '>1x/week</option>' +
              '<option ' + (b.package==="2x/week"?"selected":"") + '>2x/week</option>' +
              '<option ' + (b.package==="3x/week"?"selected":"") + '>3x/week</option>' +
              '<option ' + (b.package==="Drop-in"?"selected":"") + '>Drop-in</option>' +
              '<option ' + (b.package==="Online Only"?"selected":"") + '>Online Only</option>' +
              '<option ' + (b.package==="In-person + Online"?"selected":"") + '>In-person + Online</option>' +
            '</select></div>' +
        '</div>' +
        '<div class="billing-total">' +
          '<div class="billing-total-label">Total This Month</div>' +
          '<div class="billing-total-value" id="b-total">' + fmt$(leadTotal(L)) + '</div>' +
        '</div>' +
        '<div class="billing-toggle" id="b-paid-row" style="margin-top:14px;margin-bottom:0;padding:12px;border-radius:8px;background:' + (b.paid?"rgba(34,197,94,0.12)":"var(--panel)") + ';border:1px solid ' + (b.paid?"rgba(34,197,94,0.4)":"var(--border)") + ';">' +
          '<input type="checkbox" id="b-paid" ' + (b.paid?"checked":"") + '>' +
          '<label for="b-paid" style="font-weight:600;cursor:pointer;color:' + (b.paid?"var(--won)":"var(--text)") + ';">' + (b.paid?"✓ Paid for this month":"Mark as Paid for this month") + '</label>' +
        '</div>' +
      '</div>' +

      '<div class="section-title">Deal Status</div>' +
      '<div class="status-row" id="m-status">' + sb + '</div>' +

      '<div id="dyn-profile-mount"></div>' +
'<div class="section-title">Consultation</div>' +
      '<div class="form-field" style="margin-bottom:12px;">' +
        '<label>Consultation Status</label>' +
        '<select id="m-consult">' +
          '<option value="" ' + (!L.consultStatus?"selected":"") + '>— Set status —</option>' +
          '<option value="Complete" ' + (L.consultStatus==="Complete"?"selected":"") + '>✅ Complete</option>' +
          '<option value="Not Complete" ' + (L.consultStatus==="Not Complete"?"selected":"") + '>⬜ Not Complete</option>' +
          '<option value="Reschedule" ' + (L.consultStatus==="Reschedule"?"selected":"") + '>🔄 Reschedule</option>' +
          '<option value="Follow Up" ' + (L.consultStatus==="Follow Up"?"selected":"") + '>📌 Follow Up</option>' +
          '<option value="No Show" ' + (L.consultStatus==="No Show"?"selected":"") + '>🚫 No Show</option>' +
        '</select>' +
      '</div>' +
      '<label style="display:block;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:4px;">Notes</label>' +
      '<textarea class="notes-edit" id="m-notes" placeholder="Add notes...">' + (L.notes||"") + '</textarea>' +

      '<div class="section-title">📅 Tasks &amp; Follow-ups</div>' +
      '<div id="m-tasks">' + renderTasksForLead(L) + '</div>' +
      '<div class="task-presets">' +
        '<button class="task-preset" data-p="reachout">📞 Reach Out Tomorrow</button>' +
        '<button class="task-preset" data-p="followup">📅 Book Follow-up Next Week</button>' +
        '<button class="task-preset" data-p="text">✉️ Send Text Today</button>' +
      '</div>' +
      '<div class="task-form">' +
        '<input id="m-tnote" placeholder="Custom task note">' +
        '<input id="m-tdate" type="date" value="' + addDays(todayStr(),1) + '">' +
        '<button id="m-tadd">+ Add</button>' +
      '</div>' +

      '<div class="section-title" style="color:var(--lost);border-color:var(--lost);margin-top:30px;">⚠ Danger Zone</div>' +
      '<div style="color:var(--muted);font-size:12px;margin-bottom:10px;">Permanently remove this lead and all their tasks, notes, billing, and activity. This cannot be undone.</div>' +
      '<button class="btn-danger" id="delete-lead-btn" style="width:100%;">🗑 Delete This Lead</button>' +
    '</div>';

  $("modal").classList.add("show");

  // Wire up modal events
  $("m-star").addEventListener("click", function(){
    L.priority = !L.priority; saveState(); renderAll(); openLead(name);
  });
  $("m-status").querySelectorAll(".status-btn").forEach(function(btn){
    btn.addEventListener("click", function(){
      var fromStatus = L.status;
L.status = btn.dataset.s;
logEvent('status_changed', L.name, { from: fromStatus, to: L.status });
saveState(); renderAll(); openLead(name);
    });
  });
  $("m-notes").addEventListener("blur", function(e){ L.notes = e.target.value; saveState(); renderAll(); });
  wireDynamicProfile(L);
  if ($("m-pnote")) $("m-pnote").addEventListener("blur", function(e){ L.priorityNote = e.target.value; saveState(); renderAll(); });
  $("m-consult").addEventListener("change", function(e){
  var newStatus = e.target.value;
  var wasComplete = L.consultStatus === "Complete";
  L.consultStatus = newStatus;
  if (newStatus === "Complete" && !wasComplete && !L.followUpCreated) {
    if (!L.tasks) L.tasks = [];
    var fu = new Date();
    fu.setDate(fu.getDate() + 30);
    var dueDateStr = fu.toISOString().slice(0,10);
    L.tasks.push({ id: uuid(), type: 'Follow Up', note: '30-day follow-up after consultation', dueDate: dueDateStr, completed: false });
    L.followUpCreated = true;
    logEvent('consultation_completed', L.name, {});
    logEvent('follow_up_scheduled', L.name, { dueDate: dueDateStr });
  }
  saveState(); renderAll();
});

  // Editable profile fields — auto-save on blur (text inputs) or change (selects)
  // Legacy static profileFields loop removed — dynamic profile (renderDynamicProfile) handles all saves now.);

  // Delete lead
  $("delete-lead-btn").addEventListener("click", function(){
    if (!confirm("Permanently delete \"" + L.name + "\"? This cannot be undone.")) return;
    LEADS = LEADS.filter(function(x){ return x !== L; });
    saveState();
    closeLead();
    renderAll();
    showToast("🗑 Lead deleted: " + L.name, "error");
  });

  function updateTotal() {
    var s = parseInt($("b-sessions").value || "0");
    var r = parseInt($("b-rate").value || "0");
    $("b-total").textContent = fmt$(s * r);
  }
  $("b-active").addEventListener("change", function(e){
    b.active = e.target.checked;
if (b.active) logEvent('active_client_marked', L.name, {});
saveState(); renderAll();
updateTotal();
  });
  $("b-sessions").addEventListener("input", function(e){
    b.sessions = parseInt(e.target.value || "0");
    updateTotal();
    saveState();
    renderRevenueBanner();
    renderTabCounts();
  });
  $("b-rate").addEventListener("input", function(e){
    b.rate = parseInt(e.target.value || "0");
    updateTotal();
    saveState();
    renderRevenueBanner();
    renderTabCounts();
  });
  $("b-package").addEventListener("change", function(e){
    b.package = e.target.value;
    saveState(); renderAll();
  });
  $("b-paid").addEventListener("change", function(e){
    b.paid = e.target.checked;
if (b.paid) logEvent('payment_marked', L.name, { amount: leadTotal(L) });
saveState();
renderRevenueBanner();
    // Live-update the paid row styling + label
    var row = $("b-paid-row");
    var lbl = row.querySelector("label");
    if (b.paid) {
      row.style.background = "rgba(34,197,94,0.12)";
      row.style.borderColor = "rgba(34,197,94,0.4)";
      lbl.style.color = "var(--won)";
      lbl.textContent = "✓ Paid for this month";
    } else {
      row.style.background = "var(--panel)";
      row.style.borderColor = "var(--border)";
      lbl.style.color = "var(--text)";
      lbl.textContent = "Mark as Paid for this month";
    }
  });

  document.querySelectorAll("[data-r]").forEach(function(btn){
    btn.addEventListener("click", function(){
      var a = btn.dataset.r;
      if (a === "call") doCall(L);
      else if (a === "text") doText(L);
      else if (a === "email") doEmail(L);
      else if (a === "video") doVideo(L);
      else if (a === "voicemail") doVM(L);
    });
  });

  document.querySelectorAll("[data-p]").forEach(function(btn){
    btn.addEventListener("click", function(){
      var p = btn.dataset.p;
      if (p === "reachout") addTask(L, "Reach Out", addDays(todayStr(),1), "");
      else if (p === "followup") addTask(L, "Book Follow-up", addDays(todayStr(),7), "");
      else if (p === "text") addTask(L, "Send Text", todayStr(), "");
      renderAll(); openLead(name);
    });
  });
  $("m-tadd").addEventListener("click", function(){
    var note = $("m-tnote").value.trim();
    var d = $("m-tdate").value;
    if (!note && !d) return;
    addTask(L, note ? "Task" : "Reminder", d, note);
    renderAll(); openLead(name);
  });
  document.querySelectorAll("[data-mt]").forEach(function(btn){
    btn.addEventListener("click", function(){
      var t = leadTasks(L).find(function(x){ return x.id === btn.dataset.mt; });
      if (!t) return;
      t.completed = !t.completed;
      saveState(); renderAll(); openLead(name);
    });
  });
  document.querySelectorAll("[data-md]").forEach(function(btn){
    btn.addEventListener("click", function(){
      L.tasks = leadTasks(L).filter(function(x){ return x.id !== btn.dataset.md; });
      saveState(); renderAll(); openLead(name);
    });
  });
}

function closeLead() { $("modal").classList.remove("show"); }

// ==========================================================
// REACH OUT (Call / Text / Email / Video / Voicemail)
// ==========================================================
var callTimer = null;
function showReach(html) { $("reach-content").innerHTML = html; $("reach-modal").classList.add("show"); }
function closeReach() { $("reach-modal").classList.remove("show"); if (callTimer) { clearInterval(callTimer); callTimer = null; } }

function doCall(L) {
  showReach(
    '<div class="modal-head"><div class="modal-title">📞 Active Call</div><button class="modal-close" onclick="closeReach()">✕</button></div>' +
    '<div class="modal-body"><div class="dialer">' +
    '<div class="dialer-status" id="d-status">Calling...</div>' +
    '<div class="dialer-avatar ringing" id="d-avatar">' + L.name.charAt(0).toUpperCase() + '</div>' +
    '<div class="dialer-name">' + L.name + '</div>' +
    '<div class="dialer-phone">' + (L.phone||"No phone") + '</div>' +
    '<div class="dialer-timer" id="d-timer" style="visibility:hidden;">00:00</div>' +
    '<div class="dialer-controls">' +
      '<button class="dialer-ctrl">🔇<br>Mute</button>' +
      '<button class="dialer-ctrl">⌨️<br>Keypad</button>' +
      '<button class="dialer-ctrl">🔊<br>Speaker</button>' +
      '<button class="dialer-ctrl">⏸<br>Hold</button>' +
      '<button class="dialer-ctrl">⏺<br>Record</button>' +
      '<button class="dialer-ctrl">↪<br>Transfer</button>' +
    '</div>' +
    '<button class="dialer-end" id="d-end">📞</button>' +
    '<div class="demo-banner">⚠️ Demo mode — wire up Twilio/RingDNA after backend.</div>' +
    '</div></div>'
  );
  var secs = 0;
  setTimeout(function(){
    if (!$("d-status")) return;
    $("d-status").textContent = "Connected";
    $("d-status").classList.add("connected");
    $("d-avatar").classList.remove("ringing");
    $("d-timer").style.visibility = "visible";
    callTimer = setInterval(function(){
      secs++;
      var m = String(Math.floor(secs/60)).padStart(2,"0");
      var s = String(secs%60).padStart(2,"0");
      if ($("d-timer")) $("d-timer").textContent = m + ":" + s;
    }, 1000);
  }, 1500);
  $("d-end").addEventListener("click", function(){
    var dur = $("d-timer").textContent;
    logActivity(L, "call", secs > 0 ? "Outbound call · " + dur : "Outbound call · no answer");
    closeReach(); openLead(L.name);
  });
  document.querySelectorAll(".dialer-ctrl").forEach(function(btn){
    btn.addEventListener("click", function(){ btn.classList.toggle("active"); });
  });
}

function doText(L) {
  if (!Array.isArray(L.smsThread)) L.smsThread = [];
  function render() {
    return L.smsThread.length
      ? L.smsThread.map(function(m){ return '<div class="bubble ' + (m.from==="me"?"outgoing":"incoming") + '">' + m.body + '</div>'; }).join("")
      : '<div style="color:var(--muted);text-align:center;padding:30px 0;font-size:12px;">No messages yet. Send the first one.</div>';
  }
  showReach(
    '<div class="modal-head"><div><div class="modal-title">💬 ' + L.name + '</div><div style="color:var(--muted);font-size:12px;">' + (L.phone||"No phone") + '</div></div><button class="modal-close" onclick="closeReach()">✕</button></div>' +
    '<div class="modal-body">' +
    '<div class="sms-thread" id="sms-t">' + render() + '</div>' +
    '<div class="sms-composer"><input id="sms-in" placeholder="Type a message..."><button class="sms-send" id="sms-go">➤</button></div>' +
    '<div class="demo-banner">⚠️ Demo mode — wire up Twilio for real SMS.</div>' +
    '</div>'
  );
  function send() {
    var v = $("sms-in").value.trim();
    if (!v) return;
    L.smsThread.push({ from: "me", body: v, at: new Date().toISOString() });
    saveState();
    $("sms-t").innerHTML = render();
    $("sms-in").value = "";
    $("sms-t").scrollTop = $("sms-t").scrollHeight;
    logActivity(L, "text", 'SMS: "' + v.slice(0,50) + (v.length>50?"…":"") + '"');
  }
  $("sms-go").addEventListener("click", send);
  $("sms-in").addEventListener("keydown", function(e){ if (e.key === "Enter") send(); });
  $("sms-in").focus();
}

function doEmail(L) {
  var to = (L.name||"").toLowerCase().replace(/[^a-z]+/g,".").replace(/^\.|\.$/g,"") + "@gmail.com";
  showReach(
    '<div class="modal-head"><div class="modal-title">✉️ New Email</div><button class="modal-close" onclick="closeReach()">✕</button></div>' +
    '<div class="modal-body"><div class="email-form">' +
    '<div class="label-row"><label>From</label><input value="mario@yourdomain.com" readonly></div>' +
    '<div class="label-row"><label>To</label><input id="e-to" value="' + to + '"></div>' +
    '<div class="label-row"><label>Subject</label><input id="e-subj"></div>' +
    '<div class="label-row"><label>Template</label><select id="e-tpl"><option value="">— Pick one —</option><option value="welcome">Welcome</option><option value="followup">Post-consult follow-up</option><option value="booking">Booking confirmation</option><option value="checkin">Check-in</option></select></div>' +
    '<textarea id="e-body" placeholder="Write your message..."></textarea>' +
    '<div style="display:flex;justify-content:flex-end;"><button class="btn" id="e-send">Send Email</button></div>' +
    '<div class="demo-banner">⚠️ Demo mode — wire up SendGrid/Resend for real sending.</div>' +
    '</div></div>'
  );
  $("e-tpl").addEventListener("change", function(e){
    var first = L.name.split(" ")[0];
    var tpls = {
      welcome: { s: "Welcome to your fitness journey, " + first, b: "Hey " + first + ",\n\nThanks for filling out the form. I'll text you tomorrow to set up your first session.\n\n— Mario" },
      followup: { s: "Quick follow-up", b: "Hey " + first + ",\n\nWanted to follow up. Ready to lock in your first session?\n\n— Mario" },
      booking: { s: "Confirming your first session", b: "Hey " + first + ",\n\nConfirming your first session. See you then!\n\n— Mario" },
      checkin: { s: "How's it going, " + first + "?", b: "Hey " + first + ",\n\nQuick check-in. How's everything going? Any roadblocks?\n\n— Mario" }
    };
    var t = tpls[e.target.value];
    if (t) { $("e-subj").value = t.s; $("e-body").value = t.b; }
  });
  $("e-send").addEventListener("click", function(){
    var subj = $("e-subj").value.trim() || "(no subject)";
    if (!$("e-body").value.trim()) { alert("Add a message body."); return; }
    logActivity(L, "email", 'Email: "' + subj + '"');
    closeReach(); openLead(L.name);
  });
}

function doVideo(L) {
  showReach(
