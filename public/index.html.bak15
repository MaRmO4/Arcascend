var SUPABASE_URL = 'https://udzfpeztwgsynjhwjwic.supabase.co';

function logEvent(eventType, leadName, extraData) {
  try {
    fetch(SUPABASE_URL + '/rest/v1/lead_events', {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + SUPABASE_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({
        user_id: localStorage.getItem('arcascend_user_id'),
        lead_name: leadName || null,
        event_type: eventType,
        event_data: extraData || {}
      })
    }).catch(function(e){ console.warn('logEvent failed:', e); });
  } catch(e) { console.warn('logEvent error:', e); }
}

async function refreshAuthToken() {
  var refresh = localStorage.getItem('arcascend_refresh_token');
  if (!refresh) { console.warn('No refresh token stored. User needs to log in again.'); return false; }
  try {
    var res = await fetch(SUPABASE_URL + '/auth/v1/token?grant_type=refresh_token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY },
      body: JSON.stringify({ refresh_token: refresh })
    });
    var data = await res.json();
    if (data.error || !data.access_token) {
      console.warn('Token refresh failed:', data.error || data);
      // Don't auto-logout on refresh failure — the existing token may still be valid.
      // The app will redirect to login.html naturally if/when the access token also fails.
      return false;
    }
    localStorage.setItem('arcascend_token', data.access_token);
    if (data.refresh_token) localStorage.setItem('arcascend_refresh_token', data.refresh_token);
    localStorage.setItem('arcascend_token_expires_at', String(Date.now() + (data.expires_in || 3600) * 1000));
    return true;
  } catch (e) {
    console.warn('Token refresh error:', e);
    return false;
  }
}

async function ensureFreshToken() {
  var expiresAt = parseInt(localStorage.getItem('arcascend_token_expires_at') || '0', 10);
  if (!expiresAt || Date.now() > expiresAt - 5 * 60 * 1000) {
    await refreshAuthToken();
  }
}

// Refresh only when token is near expiry; recheck every 5 minutes
function maybeRefresh() {
  if (!localStorage.getItem('arcascend_refresh_token')) return;
  var expiresAt = parseInt(localStorage.getItem('arcascend_token_expires_at') || '0', 10);
  if (!expiresAt) return; // fresh login already valid; nothing to do yet
  if (Date.now() > expiresAt - 5 * 60 * 1000) refreshAuthToken();
}
maybeRefresh();
setInterval(maybeRefresh, 5 * 60 * 1000);
loadTrainerQuestions();


var calMonth = new Date(); calMonth.setDate(1);
function renderCalendarTab(){
  var main = $("main");
  main.innerHTML = '<div style="padding:20px;color:var(--text-muted)">Loading calendar...</div>';
  var token = localStorage.getItem('arcascend_token');

  fetch(SUPABASE_URL + '/rest/v1/lead_events?user_id=eq.' + (currentUser?currentUser.id:'') + '&event_type=eq.lead_created&select=lead_name,created_at&order=created_at.desc&limit=500', {
    headers: { 'Authorization': 'Bearer ' + token, 'apikey': SUPABASE_KEY }
  }).then(function(r){ return r.ok ? r.json() : []; }).catch(function(){ return []; }).then(function(events){
    drawCalendar(events || []);
  });

  function ymd(d){ return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'); }
  function parseLeadDate(str){ if(!str) return null; var d = new Date(str); return isNaN(d.getTime()) ? null : d; }

  function drawCalendar(events){
    var dayMap = {};
    function addToDay(key, kind, item){ if(!dayMap[key]) dayMap[key] = { tasks:[], newleads:[], intakes:[] }; dayMap[key][kind].push(item); }

    LEADS.forEach(function(L){
      leadTasks(L).forEach(function(t){
        if (t.dueDate && !t.completed) addToDay(t.dueDate, 'tasks', { lead: L.name, type: t.type, note: t.note });
      });
      var d = parseLeadDate(L.date);
      if (d) addToDay(ymd(d), 'intakes', { lead: L.name, status: L.status });
    });
    events.forEach(function(ev){
      var d = new Date(ev.created_at);
      if (!isNaN(d.getTime())) addToDay(ymd(d), 'newleads', { lead: ev.lead_name });
    });

    var year = calMonth.getFullYear(), month = calMonth.getMonth();
    var firstDay = new Date(year, month, 1);
    var startOffset = firstDay.getDay();
    var daysInMonth = new Date(year, month+1, 0).getDate();
    var todayKey = ymd(new Date());
    var dotStyle = 'display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:3px;';

    var html = '<div style="padding:20px;">';
    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">';
    html += '<button id="cal-prev" style="background:var(--panel);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:6px 12px;cursor:pointer;">‹ Prev</button>';
    html += '<div style="font-size:18px;font-weight:600;">' + firstDay.toLocaleString('default',{month:'long', year:'numeric'}) + '</div>';
    html += '<button id="cal-next" style="background:var(--panel);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:6px 12px;cursor:pointer;">Next ›</button>';
    html += '</div>';
    html += '<div style="display:flex;gap:14px;margin-bottom:12px;font-size:12px;color:var(--text-muted);align-items:center;">';
    html += '<span><span style="'+dotStyle+'background:#3b82f6;"></span>Tasks / Follow-ups</span>';
    html += '<span><span style="'+dotStyle+'background:#22c55e;"></span>New Leads</span>';
    html += '<span><span style="'+dotStyle+'background:#f59e0b;"></span>Intake / Consultation</span>';
    html += '</div>';
    html += '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;">';
    ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(d){ html += '<div style="text-align:center;font-size:11px;color:var(--text-muted);font-weight:600;padding:4px 0;">'+d+'</div>'; });
    for (var i=0;i<startOffset;i++) html += '<div></div>';
    for (var day=1; day<=daysInMonth; day++){
      var dcell = new Date(year, month, day);
      var key = ymd(dcell);
      var info = dayMap[key] || { tasks:[], newleads:[], intakes:[] };
      var isToday = key === todayKey;
      html += '<div data-cal-day="'+key+'" style="min-height:64px;border:1px solid '+(isToday?'var(--accent)':'var(--border)')+';border-radius:8px;padding:6px;cursor:pointer;background:'+(isToday?'rgba(79,158,255,0.08)':'var(--panel)')+';">';
      html += '<div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">'+day+'</div>';
      html += '<div>';
      if (info.tasks.length) html += '<span style="'+dotStyle+'background:#3b82f6;" title="'+info.tasks.length+' task(s)"></span>';
      if (info.newleads.length) html += '<span style="'+dotStyle+'background:#22c55e;" title="'+info.newleads.length+' new lead(s)"></span>';
      if (info.intakes.length) html += '<span style="'+dotStyle+'background:#f59e0b;" title="'+info.intakes.length+' intake(s)"></span>';
      html += '</div></div>';
    }
    html += '</div>';
    html += '<div id="cal-day-detail" style="margin-top:20px;"></div>';
    html += '</div>';

    main.innerHTML = html;
    window.__CAL_DAYMAP = dayMap;

    $("cal-prev").addEventListener("click", function(){ calMonth.setMonth(calMonth.getMonth()-1); renderCalendarTab(); });
    $("cal-next").addEventListener("click", function(){ calMonth.setMonth(calMonth.getMonth()+1); renderCalendarTab(); });

    document.querySelectorAll("[data-cal-day]").forEach(function(cell){
      cell.addEventListener("click", function(){
        var key = cell.dataset.calDay;
        var info = window.__CAL_DAYMAP[key] || { tasks:[], newleads:[], intakes:[] };
        var detail = document.getElementById('cal-day-detail');
        var h = '<div style="font-weight:600;font-size:14px;margin-bottom:10px;">' + key + '</div>';
        if (!info.tasks.length && !info.newleads.length && !info.intakes.length) {
          h += '<div style="color:var(--text-muted);font-size:13px;">No events this day.</div>';
        } else {
          if (info.tasks.length){
            h += '<div style="font-size:11px;text-transform:uppercase;color:var(--text-muted);margin:10px 0 4px;">Tasks / Follow-ups</div>';
            info.tasks.forEach(function(t){ h += '<div style="font-size:13px;padding:4px 0;border-bottom:1px solid var(--border);"><b>'+t.type+'</b> — '+t.lead+(t.note?' ('+t.note+')':'')+'</div>'; });
          }
          if (info.newleads.length){
            h += '<div style="font-size:11px;text-transform:uppercase;color:var(--text-muted);margin:10px 0 4px;">New Leads</div>';
            info.newleads.forEach(function(n){ h += '<div style="font-size:13px;padding:4px 0;border-bottom:1px solid var(--border);">'+n.lead+'</div>'; });
          }
          if (info.intakes.length){
            h += '<div style="font-size:11px;text-transform:uppercase;color:var(--text-muted);margin:10px 0 4px;">Intake / Consultation</div>';
            info.intakes.forEach(function(n){ h += '<div style="font-size:13px;padding:4px 0;border-bottom:1px solid var(--border);">'+n.lead+' — '+n.status+'</div>'; });
          }
        }
        detail.innerHTML = h;
      });
    });
  }
}

