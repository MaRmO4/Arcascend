var monthlyGoal = 0;

// ==========================================================
// HELPERS
// ==========================================================
function $(id) { return document.getElementById(id); }
function uuid() { return Math.random().toString(36).slice(2) + Date.now().toString(36); }
function leadKey(L) {
var name = (L.name || "").trim().toLowerCase();
  var phone = (L.phone || "").replace(/\D/g, "").slice(-10);
  var email = (L.email || "").trim().toLowerCase();
  return name + "|" + phone + "|" + email;
}
function statusClass(s) {
  s = (s||"").toLowerCase();
  if (s.indexOf("won") >= 0) return "won";
  if (s.indexOf("lost") >= 0) return "lost";
  if (s.indexOf("pending") >= 0) return "pending";
  if (s.indexOf("open") >= 0) return "open";
  return "new";
}
function todayStr() { return new Date().toISOString().slice(0,10); }
function addDays(d, n) {
  var date = d ? new Date(d+"T00:00:00") : new Date();
  date.setDate(date.getDate()+n);
  return date.toISOString().slice(0,10);
}
function formatTaskDate(d) {
  if (!d) return "";
  var t = todayStr();
  if (d === t) return "Today";
  if (d === addDays(t,1)) return "Tomorrow";
  if (d === addDays(t,-1)) return "Yesterday";
  return new Date(d+"T00:00:00").toLocaleDateString("en-US",{month:"short",day:"numeric"});
}
function dueBucket(d) {
  if (!d) return "upcoming";
  var t = todayStr();
  if (d < t) return "overdue";
  if (d === t) return "today";
  if (d === addDays(t,1)) return "tomorrow";
  if (d <= addDays(t,7)) return "thisweek";
  return "upcoming";
}
function timeAgo(iso) {
  var d = new Date(iso), diff = (Date.now()-d.getTime())/1000;
  if (diff < 60) return "just now";
  if (diff < 3600) return Math.floor(diff/60) + " min ago";
  if (diff < 86400) return Math.floor(diff/3600) + "h ago";
  if (diff < 86400*7) return Math.floor(diff/86400) + "d ago";
  return d.toLocaleDateString();
}
function fmt$(n) {
  return "$" + (n || 0).toLocaleString();
}

// ==========================================================
// BILLING HELPERS
// ==========================================================
function ensureBilling(L) {
  if (!L.billing) L.billing = { active: false, sessions: 0, rate: 0, package: "", paid: false };
  if (L.billing.paid === undefined) L.billing.paid = false;
  return L.billing;
}
function leadTotal(L) {
  var b = ensureBilling(L);
  return (b.sessions || 0) * (b.rate || 0);
}
function activeClients() {
  return LEADS.filter(function(L){ return L.billing && L.billing.active; });
}
function totalRevenue() {
  var t = 0;
  activeClients().forEach(function(L){ t += leadTotal(L); });
  return t;
}
function totalPaid() {
  var t = 0;
  activeClients().forEach(function(L){ if (L.billing.paid) t += leadTotal(L); });
  return t;
}
function totalOutstanding() {
  return totalRevenue() - totalPaid();
}

// ==========================================================
// TASKS
// ==========================================================
function leadTasks(L) {
  if (!Array.isArray(L.tasks)) L.tasks = [];
  return L.tasks;
}
function openTaskCount(L) {
  return leadTasks(L).filter(function(t){ return !t.completed; }).length;
}
function nextOpenTask(L) {
  var open = leadTasks(L).filter(function(t){ return !t.completed; });
  open.sort(function(a,b){ return (a.dueDate||"") < (b.dueDate||"") ? -1 : 1; });
  return open[0];
}
function addTask(L, type, dueDate, note) {
  leadTasks(L).push({ id: uuid(), type: type, dueDate: dueDate, note: note||"", completed: false });
  saveState();
}

// ==========================================================
// ACTIVITY
// ==========================================================
function activityList(L) {
  if (!Array.isArray(L.activity)) L.activity = [];
  // Normalize legacy entries ({type, text, ts}) to current schema ({kind, summary, at}).
  return L.activity.map(function(a){
    if (a && a.kind && a.summary && a.at) return a;
    var kind = a.kind || a.type || 'note';
    var summary = a.summary || a.text || '';
    var at = a.at;
    if (!at && a.ts) at = new Date(a.ts).toISOString();
    if (!at) at = new Date().toISOString();
    return { kind: kind, summary: summary, at: at };
  });
}
function logActivity(L, kind, summary) {
  activityList(L).unshift({ kind: kind, summary: summary, at: new Date().toISOString() });
  if (L.activity.length > 20) L.activity = L.activity.slice(0,20);
  saveState();
}

