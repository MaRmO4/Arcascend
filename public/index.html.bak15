// Check if user is logged in
async function checkAuth() {
  var token = localStorage.getItem('arcascend_token');
  var userId = localStorage.getItem('arcascend_user_id');
  if (!token || !userId) {
    window.location.href = 'login.html';
    return false;
  }
  currentUser = { 
    id: userId,
    email: localStorage.getItem('arcascend_user_email')
  };
  return true;
}
// Save leads to Supabase
async function saveToSupabase() {
  var token = localStorage.getItem('arcascend_token');
  if (!token || !currentUser) return;
  try {
    await fetch(SUPABASE_URL + '/rest/v1/leads?user_id=eq.' + currentUser.id, {
      method: 'DELETE',
      headers: {
        'Authorization': 'Bearer ' + token,
        'apikey': SUPABASE_KEY,
        'Content-Type': 'application/json'
      }
    });
    if (!LEADS.length) return;
    var rows = LEADS.map(function(L) {
      return {
        user_id: currentUser.id,
        name: L.name || '',
        phone: L.phone || '',
        email: L.email || '',
        goal: L.goal || '',
        status: L.status || 'New',
        data: JSON.stringify(L)
      };
    });
    await fetch(SUPABASE_URL + '/rest/v1/leads', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + token,
        'apikey': SUPABASE_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify(rows)
    });
  } catch(e) {
    console.log('Supabase save error:', e);
  }
}

