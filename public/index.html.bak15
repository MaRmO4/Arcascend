function openAdd() {
  $("add-modal").classList.add("show");
  $("add-date").value = new Date().toLocaleDateString("en-US");
}
function closeAdd() { $("add-modal").classList.remove("show"); }
function openSettings() {
  $("monthly-goal").value = monthlyGoal || "";
  $("settings-modal").classList.add("show");
}
function closeSettings() { $("settings-modal").classList.remove("show"); }

// ==========================================================
// FILTER UI
// ==========================================================
function activeFilterCount() {
  var n = 0;
  Object.keys(F).forEach(function(k){ if (F[k]) n++; });
  return n;
}
function refreshFilterUI() {
  var n = activeFilterCount();
  var badge = $("filter-badge");
  badge.textContent = n;
  badge.style.display = n ? "inline-flex" : "none";
  $("filter-toggle").classList.toggle("has-filters", n > 0);
  $("save-tab-btn").disabled = n === 0;
  var chips = $("active-chips");
  var items = Object.keys(F).filter(function(k){ return F[k]; });
  chips.innerHTML = items.length
    ? items.map(function(k){ return '<span class="chip">' + k + ': ' + F[k] + ' <span class="chip-x" data-cf="' + k + '">✕</span></span>'; }).join("")
    : '<span style="color:var(--muted);font-size:12px;">No filters</span>';
  chips.querySelectorAll("[data-cf]").forEach(function(el){
    el.addEventListener("click", function(){
      var k = el.dataset.cf;
      F[k] = "";
      var inp = $("f-" + k); if (inp) inp.value = "";
      refreshFilterUI(); renderMain();
    });
  });
}

// ==========================================================
// .ICS EXPORT
// ==========================================================
function buildICS() {
  var lines = ["BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//ArcAscend//EN","CALSCALE:GREGORIAN","X-WR-CALNAME:ArcAscend Tasks"];
  var count = 0;
  function pad(n) { return String(n).padStart(2,"0"); }
  var d = new Date();
  var stamp = d.getUTCFullYear() + pad(d.getUTCMonth()+1) + pad(d.getUTCDate()) + "T" + pad(d.getUTCHours()) + pad(d.getUTCMinutes()) + pad(d.getUTCSeconds()) + "Z";
  LEADS.forEach(function(L){
    leadTasks(L).forEach(function(t){
      if (t.completed || !t.dueDate) return;
      var start = t.dueDate.replace(/-/g,"");
      var dt = new Date(t.dueDate + "T00:00:00");
      dt.setDate(dt.getDate()+1);
      var end = dt.getFullYear() + pad(dt.getMonth()+1) + pad(dt.getDate());
      function esc(s){ return (s||"").replace(/\\/g,"\\\\").replace(/;/g,"\\;").replace(/,/g,"\\,").replace(/\n/g,"\\n"); }
      lines.push("BEGIN:VEVENT");
      lines.push("UID:" + t.id + "@arcascend");
      lines.push("DTSTAMP:" + stamp);
      lines.push("DTSTART;VALUE=DATE:" + start);
      lines.push("DTEND;VALUE=DATE:" + end);
      lines.push("SUMMARY:" + esc(t.type + " — " + L.name));
      var desc = [];
      if (t.note) desc.push(t.note);
      if (L.phone) desc.push("Phone: " + L.phone);
      if (desc.length) lines.push("DESCRIPTION:" + esc(desc.join("\n")));
      lines.push("END:VEVENT");
      count++;
    });
  });
  lines.push("END:VCALENDAR");
  return { ics: lines.join("\r\n"), count: count };
}
  function renderFollowUpReminders() {
  const now = new Date();
  const reminders = [];

  (LEADS || []).forEach(function(lead) {
if (lead.status === 'Closed Won' || lead.status === 'Closed Lost') return;
    const activities = (window.activityLog || []).filter(function(a) { return a.lead_id === lead.id; });
    const lastContact = activities
      .filter(function(a) { return ['call','note','task'].includes(a.type); })
      .sort(function(a,b) { return new Date(b.created_at) - new Date(a.created_at); })[0];

   const created = lead.created_at ? new Date(lead.created_at) : new Date();
    const lastDate = lastContact ? new Date(lastContact.created_at) : created;   
    const daysSince = Math.floor((now - lastDate) / (1000 * 60 * 60 * 24));

    if (!lastContact && daysSince < 2) {
      reminders.push({ name: lead.name, meta: 'New lead · Added ' + (daysSince === 0 ? 'today' : daysSince + 'd ago'), badge: 'New Lead', type: 'new-lead', priority: 0, leadId: lead.id });
    } else if (daysSince >= 14) {
      reminders.push({ name: lead.name, meta: 'No contact in ' + daysSince + ' days', badge: daysSince + 'd overdue', type: 'urgent', priority: 2, leadId: lead.id });
    } else if (daysSince >= 7) {
      reminders.push({ name: lead.name, meta: 'No contact in ' + daysSince + ' days', badge: daysSince + 'd overdue', type: '', priority: 1, leadId: lead.id });
    }
  });

  // Low sessions — filter active clients from LEADS
  (LEADS || []).filter(function(l) { return l.billing && l.billing.active === true; }).forEach(function(client) {
    var total = (client.billing && client.billing.sessions) || 0;
    var paid = (client.billing && client.billing.paid) ? 1 : 0;
    var used = client.sessionsUsed || client.sessions_used || 0;
    var remaining = total - used;
    if (total > 0 && remaining / total <= 0.2) {
      reminders.push({ name: client.name, meta: remaining + ' session' + (remaining !== 1 ? 's' : '') + ' remaining of ' + total, badge: 'Low sessions', type: remaining === 0 ? 'urgent' : '', priority: remaining === 0 ? 2 : 1, leadId: client.id });
    }
  });

  if (reminders.length === 0) return '';
  reminders.sort(function(a,b) { return b.priority - a.priority; });

  var rows = reminders.slice(0, 8).map(function(r) {
return '<div class="reminder-row ' + r.type + '" onclick="openLead(\'' + r.name.replace(/'/g, "\\'") + '\')">' +      '<div><div class="reminder-name">' + r.name + '</div><div class="reminder-meta">' + r.meta + '</div></div>' +
      '<span class="reminder-badge ' + r.type + '">' + r.badge + '</span></div>';
  }).join('');

  return '<div style="background:var(--panel);border-radius:12px;padding:16px;margin-bottom:16px;border:1px solid var(--border);">' +
    '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">' +
    '<span style="font-size:13px;font-weight:700;color:var(--text);">⏰ Follow-Up Reminders</span>' +
    '<span style="font-size:11px;color:var(--muted);">' + reminders.length + ' need attention</span></div>' +
    '<div style="display:flex;flex-direction:column;gap:6px;">' + rows + '</div></div>';
}
function refreshReminders() {
  var el = document.getElementById('reminders-container');
  if (el) el.innerHTML = renderFollowUpReminders();
}
function renderHomeTab() {
  var panel = document.getElementById('home-panel');
  if (!panel) return;

  // Show/hide panel
  var isHome = (typeof currentTab !== 'undefined') && currentTab === 'home';
  panel.style.display = isHome ? 'block' : 'none';
  if (!isHome) return;
document.getElementById('main').style.display = 'none';
  document.getElementById('home-panel').style.display = 'block';

  // STAT CARDS
 var activeClients = LEADS.filter(function(l) {
  var b = l.billing || {};
  return b.active === true;
});
  var totalProjection = LEADS.reduce(function(sum, l) {
  var b = l.billing || {};
  return sum + ((b.sessions || 0) * (b.rate || 0));
}, 0);
var totalPaid = LEADS.reduce(function(sum, l) {
  var b = l.billing || {};
  return sum + (b.paid ? ((b.sessions || 0) * (b.rate || 0)) : 0);
}, 0);
  var outstanding = Math.max(0, totalProjection - totalPaid);

  panel.innerHTML =
    '<div style="margin-bottom:8px;">' +
      '<h2 style="font-size:20px;font-weight:700;color:var(--text);margin-bottom:4px;">🏠 Home</h2>' +
      '<div style="font-size:13px;color:var(--muted);">Welcome back! Here\'s your overview.</div>' +
    '</div>' +

    // STAT CARDS ROW
    '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;margin-top:20px;">' +
      '<div class="home-stat-card">' +
        '<div class="home-stat-label">Monthly Projection</div>' +
        '<div class="home-stat-value">$' + totalProjection.toLocaleString() + '</div>' +
      '</div>' +
      '<div class="home-stat-card" style="border-color:#22c55e;">' +
        '<div class="home-stat-label">Paid So Far</div>' +
        '<div class="home-stat-value" style="color:#22c55e;">$' + totalPaid.toLocaleString() + '</div>' +
      '</div>' +
      '<div class="home-stat-card" style="border-color:#f59e0b;">' +
        '<div class="home-stat-label">Outstanding</div>' +
        '<div class="home-stat-value" style="color:#f59e0b;">$' + outstanding.toLocaleString() + '</div>' +
      '</div>' +
      '<div class="home-stat-card">' +
        '<div class="home-stat-label">Active Clients</div>' +
        '<div class="home-stat-value">' + activeClients.length + '</div>' +
      '</div>' +
    '</div>' +

    // 3 COLUMN GRID
    '<div id="reminders-container"></div>' +
'<div style="display:grid;grid-template-columns:1fr 1.4fr 1fr;gap:16px;">' +

      // LEFT COL: Tasks + Calendar
      '<div style="display:flex;flex-direction:column;gap:16px;">' +
        '<div class="home-card">' +
          '<div class="home-card-title">📋 Tasks Due Soon</div>' +
          '<div class="home-card-body" id="home-tasks-list"></div>' +
        '</div>' +
        '<div class="home-card">' +
          '<div class="home-card-title">📅 Upcoming Appointments</div>' +
          '<div class="home-card-body" id="home-calendar-list"></div>' +
        '</div>' +
      '</div>' +

      // MIDDLE COL: Recent Leads
      '<div class="home-card">' +
        '<div class="home-card-title">🔥 New & Recent Leads</div>' +
        '<div class="home-card-body" id="home-recent-leads"></div>' +
      '</div>' +

      // RIGHT COL: Favorites + Revenue
      '<div style="display:flex;flex-direction:column;gap:16px;">' +
        '<div class="home-card">' +
          '<div class="home-card-title">⭐ Favorites</div>' +
          '<div class="home-card-body" id="home-favorites-list"></div>' +
        '</div>' +
        '<div class="home-card">' +
          '<div class="home-card-title">💰 Revenue Breakdown</div>' +
          '<div class="home-card-body" id="home-revenue-breakdown"></div>' +
        '</div>' +
      '</div>' +

    '</div>';

  // RECENT LEADS
  var recentEl = document.getElementById('home-recent-leads');
  if (recentEl) {
    var sorted = LEADS.slice().sort(function(a, b) {
      return new Date(b.date || 0) - new Date(a.date || 0);
    }).slice(0, 12);
    recentEl.innerHTML = sorted.length === 0 ? '<div class="home-empty">No leads yet</div>' :
      sorted.map(function(l) {
        var s = (l.status || 'New');
        var sc = s.toLowerCase().includes('active') ? '#22c55e' : s.toLowerCase().includes('won') ? '#a78bfa' : '#60a5fa';
        return '<div class="home-lead-row" onclick="openLead(\'' + (l.name||'').replace(/'/g,"\\'") + '\')">' +
          '<div><div class="home-lead-name">' + (l.name || 'Unnamed') + '</div>' +
          '<div class="home-lead-meta">' + (l.goal || 'No goal listed') + '</div></div>' +
          '<span style="font-size:11px;color:' + sc + ';font-weight:600;">' + s + '</span>' +
        '</div>';
      }).join('');
  }

  // FAVORITES
  var favEl = document.getElementById('home-favorites-list');
  if (favEl) {
    var favs = LEADS.filter(function(l) { return l.priority; }).slice(0, 8);
    favEl.innerHTML = favs.length === 0 ? '<div class="home-empty">Star a lead to see them here</div>' :
      favs.map(function(l) {
        return '<div class="home-lead-row" onclick="openLead(\'' + (l.name||'').replace(/'/g,"\\'") + '\')">' +
          '<div><div class="home-lead-name">⭐ ' + (l.name || 'Unnamed') + '</div>' +
          '<div class="home-lead-meta">' + (l.status || 'New') + '</div></div>' +
        '</div>';
      }).join('');
  }

  // TASKS DUE SOON
  var tasksEl = document.getElementById('home-tasks-list');
  if (tasksEl) {
    var today = new Date(); today.setHours(0,0,0,0);
    var dueTasks = [];
    LEADS.forEach(function(l) {
      if (l.tasks && l.tasks.length) {
        l.tasks.forEach(function(t) {
    if (!t.completed && t.dueDate) dueTasks.push({ lead: l.name, task: t.note || t.text || t.title || 'Task', due: t.dueDate });    });
      }
    });
    dueTasks.sort(function(a, b) { return new Date(a.due) - new Date(b.due); });
    tasksEl.innerHTML = dueTasks.length === 0 ? '<div class="home-empty">No tasks due soon</div>' :
      dueTasks.slice(0, 8).map(function(t) {
        var d = new Date(t.due + 'T00:00:00');
        var isOverdue = d < today;
        var isToday = d.getTime() === today.getTime();
        var cls = isOverdue ? 'overdue' : isToday ? 'today' : '';
        var ds = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return '<div class="home-task-row" onclick="openLead(\'' + t.lead.replace(/'/g, "\\'") + '\')" style="cursor:pointer;"><div class="home-task-dot ' + cls + '"></div>' +
          '<div><div class="home-lead-name" style="font-size:12px;">' + t.task + '</div>' +
          '<div class="home-lead-meta">' + t.lead + ' · ' + ds + '</div></div></div>';
      }).join('');
  }

  // UPCOMING APPOINTMENTS
  var calEl = document.getElementById('home-calendar-list');
  if (calEl) {
    var upcoming = LEADS.filter(function(l) { return l.appointmentDate || l.appointment; })
      .sort(function(a,b) { return new Date(a.appointmentDate||a.appointment) - new Date(b.appointmentDate||b.appointment); })
      .slice(0, 6);
    calEl.innerHTML = upcoming.length === 0 ? '<div class="home-empty">No upcoming appointments</div>' :
      upcoming.map(function(l) {
        var d = new Date((l.appointmentDate||l.appointment) + 'T00:00:00');
        var ds = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return '<div class="home-lead-row"><div>' +
          '<div class="home-lead-name">' + (l.name||'Unnamed') + '</div>' +
          '<div class="home-lead-meta">' + ds + '</div></div></div>';
      }).join('');
  }

  // REVENUE BREAKDOWN
  var revEl = document.getElementById('home-revenue-breakdown');
  if (revEl) {
    var won = LEADS.filter(function(l) { return (l.status||'').toLowerCase().includes('won'); });
    var pipeline = LEADS.filter(function(l) {
      var s = (l.status||'').toLowerCase();
      return !s.includes('won') && !s.includes('lost');
    });
    var wonVal = won.reduce(function(s,l){ return s+((l.sessions||0)*(l.rate||0)); }, 0);
    var pipeVal = pipeline.reduce(function(s,l){ return s+((l.sessions||0)*(l.rate||0)); }, 0);
    revEl.innerHTML =
      '<div class="home-task-row"><div class="home-task-dot" style="background:#22c55e;"></div>' +
        '<div><div class="home-lead-name" style="font-size:12px;">Closed Won</div>' +
        '<div class="home-lead-meta">$' + wonVal.toLocaleString() + ' · ' + won.length + ' clients</div></div></div>' +
      '<div class="home-task-row"><div class="home-task-dot" style="background:#60a5fa;"></div>' +
        '<div><div class="home-lead-name" style="font-size:12px;">In Pipeline</div>' +
        '<div class="home-lead-meta">$' + pipeVal.toLocaleString() + ' · ' + pipeline.length + ' leads</div></div></div>' +
      '<div class="home-task-row"><div class="home-task-dot" style="background:#22c55e;"></div>' +
        '<div><div class="home-lead-name" style="font-size:12px;">Active Clients</div>' +
        '<div class="home-lead-meta">' + activeClients.length + ' training now</div></div></div>';
  }
}
// ==========================================================
// RENDER ALL
// ==========================================================
function renderAll() {if (typeof currentTab !== 'undefined' && currentTab === 'home') { renderHomeTab(); return; }
document.getElementById('home-panel').style.display = 'none';
document.getElementById('main').style.display = 'block';
renderRevenueBanner();
  renderTabCounts();
  renderCustomTabs();
  renderMain();
}

// ==========================================================
// INIT
// ==========================================================
// ── Profile Menu ──────────────────────────────────────
// ── Bulk Select & Delete ──────────────────────────────
var selectedLeads = new Set();

function updateBulkBar() {
  var bar = document.getElementById('bulk-actions-bar');
  var count = document.getElementById('selected-count');
  var selectAllCb = document.getElementById('select-all-cb');
  if (selectedLeads.size > 0) {
    bar.style.display = 'flex';
    count.textContent = selectedLeads.size + ' selected';
  } else {
    bar.style.display = 'none';
  }
  var allCards = document.querySelectorAll('.lead-card');
  selectAllCb.checked = allCards.length > 0 && selectedLeads.size === allCards.length;
}

function cancelSelection() {
  selectedLeads.clear();
  document.querySelectorAll('.lead-checkbox').forEach(function(cb) {
    cb.checked = false;
  });
  updateBulkBar();
}

function deleteSelected() {
  if (selectedLeads.size === 0) return;
  if (!confirm('Delete ' + selectedLeads.size + ' lead(s)? This cannot be undone.')) return;
  LEADS = LEADS.filter(function(L) {
    return !selectedLeads.has(L.name);
  });
  selectedLeads.clear();
  saveState();
  renderAll();
  updateBulkBar();
}

function initBulkSelect() {
  var selectAllCb = document.getElementById('select-all-cb');
  selectAllCb.addEventListener('change', function() {
    var allCards = document.querySelectorAll('.lead-card');
    if (this.checked) {
      allCards.forEach(function(card) {
        var name = card.dataset.name;
        if (name) selectedLeads.add(decodeURIComponent(name));
        var cb = card.querySelector('.lead-checkbox');
        if (cb) cb.checked = true;
      });
    } else {
      cancelSelection();
    }
    updateBulkBar();
  });
}
// ──────────────────────────────────────────────────────
function initProfileMenu() {
  var btn = document.getElementById('profile-btn');
  var dropdown = document.getElementById('profile-dropdown');
  var emailEl = document.getElementById('profile-email');
  
  // Show logged in email
  var email = localStorage.getItem('arcascend_user_email') || 'trainer@arcascend.com';
  if (emailEl) emailEl.textContent = email;

  // Toggle dropdown
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var isOpen = dropdown.style.display === 'block';
    dropdown.style.display = isOpen ? 'none' : 'block';
  });

  // Close when clicking outside
  document.addEventListener('click', function() {
    dropdown.style.display = 'none';
  });
}

function logOut() {
  localStorage.removeItem('arcascend_token');
  localStorage.removeItem('arcascend_user_id');
  localStorage.removeItem('arcascend_user_email');
  window.location.href = 'login.html';
}

function showAbout() {
  alert('ArcAscend v1.0\nCRM built for Personal Trainers & Gyms.\n\nBuilt with ❤️ for fitness professionals.');
}
// ──────────────────────────────────────────────────────
function initApp() {
  if (location.search.indexOf("reset") >= 0 || location.hash.indexOf("reset") >= 0) {
    Object.keys(localStorage).filter(function(k){ return k.indexOf("arcascend") === 0; }).forEach(function(k){ localStorage.removeItem(k); });
    location.href = location.pathname;
    return;
  }

  loadState();
  checkAuth().then(function(loggedIn) {
    if (loggedIn) {
      loadFromSupabase().then(function(loaded) {
        if (!loaded) loadState();
        loadBuckets();
        loadCampaigns();
        loadGoal();
        loadHiddenTabs();
        applyTabVisibility();
        currentTab = 'home';
document.querySelectorAll('.tab').forEach(function(x){ x.classList.remove('active'); });
var homeTab = document.querySelector('.tab[data-tab="home"]');
if (homeTab) homeTab.classList.add('active');
setTimeout(function(){ renderHomeTab(); setTimeout(refreshReminders, 400); }, 100);
        initProfileMenu();
        initBulkSelect();
      });
    }
  });

  // Edit Tabs button
  $("tabs-btn").addEventListener("click", openTabsModal);
  $("tabs-modal").addEventListener("click", function(e){ if (e.target.id === "tabs-modal") closeTabsModal(); });

  // Restore last-saved timestamp from storage
  var savedTs = localStorage.getItem(LAST_SAVED_KEY);
  if (savedTs) lastSavedAt = parseInt(savedTs);
  updateSavedIndicator();

  // Save button
  $("save-btn").addEventListener("click", function(){
    saveState();
    var b = $("save-btn");
    b.classList.add("saved");
    b.innerHTML = "Saved";
    showToast("✓ All changes saved to your browser", "success");
    setTimeout(function(){
      b.classList.remove("saved");
      b.innerHTML = "💾 Save";
    }, 2000);
  });

  // Restore polling
  var savedUrl = localStorage.getItem(SHEET_URL_KEY);
var savedAutoSync = localStorage.getItem(AUTO_SYNC_KEY) === "1";
var savedPollInt = localStorage.getItem(POLL_INT_KEY) || "300";
if (savedUrl && savedAutoSync) {
  setTimeout(function() {
    var urlInput = document.getElementById('sync-url');
    var intInput = document.getElementById('sync-int');
    if (urlInput) urlInput.value = savedUrl;
    if (intInput) intInput.value = savedPollInt;
    startPolling();
  }, 2000);
}

  // Wire tab clicks
  document.querySelectorAll(".tab[data-tab]").forEach(function(t){
    t.addEventListener("click", function(){
      document.querySelectorAll(".tab").forEach(function(x){ x.classList.remove("active"); });
      t.classList.add("active");
      activeTab = t.dataset.tab;
currentTab = t.dataset.tab;
renderAll();
if (currentTab === 'home') setTimeout(refreshReminders, 100);
    });
  });

  // Search
  $("search").addEventListener("input", function(e){ searchQ = e.target.value; renderMain(); });

  // Sort
  $("sort-by").addEventListener("change", function(e){ sortBy = e.target.value; renderMain(); });

  // Filter panel
  ["level","timeline","status","active","goal","why","availability","hastask","priority","notes"].forEach(function(k){
    var el = $("f-" + k);
    if (!el) return;
    el.addEventListener("input", function(e){ F[k] = e.target.value; refreshFilterUI(); renderMain(); });
    el.addEventListener("change", function(e){ F[k] = e.target.value; refreshFilterUI(); renderMain(); });
  });
  $("filter-toggle").addEventListener("click", function(){ $("filter-panel").classList.toggle("open"); });
  $("clear-filters").addEventListener("click", function(){
    Object.keys(F).forEach(function(k){ F[k] = ""; var el = $("f-" + k); if (el) el.value = ""; });
    refreshFilterUI(); renderMain();
  });

  // Save as tab
  $("save-tab-btn").addEventListener("click", function(){
    var name = prompt("Name this new tab:");
    if (!name) return;
    var icon = prompt("Icon emoji:", "🎯") || "🎯";
    var rule = {};
    if (F.level) rule.level = F.level;
    if (F.status) rule.status = F.status;
    if (F.active) rule.active = F.active;
    if (F.goal) rule.goal = F.goal;
    if (F.why) rule.why = F.why;
    if (F.timeline) rule.timeline = F.timeline;
    BUCKETS.push({ id: uuid(), name: name, icon: icon, desc: "Saved filter", rule: rule, pinAsTab: true });
    saveBuckets();
    renderAll();
  });

  // Add Lead
  $("add-lead-btn").addEventListener("click", openAdd);
  $("add-modal").addEventListener("click", function(e){ if (e.target.id === "add-modal") closeAdd(); });
  $("add-form").addEventListener("submit", function(e){
    e.preventDefault();
    var fd = new FormData(e.target);
    var L = {
      date: fd.get("date") || new Date().toLocaleDateString("en-US"),
      name: fd.get("name").trim(),
      phone: (fd.get("phone")||"").trim(),
      goal: fd.get("goal")||"",
      level: fd.get("level")||"",
      timeline: fd.get("timeline")||"",
      style: "", injuries: "", availability: "", whyNow: "", outcomes: "", other: "",
      notes: fd.get("notes")||"",
      status: fd.get("status")||"New",
      billing: { active: false, sessions: 0, rate: 0, package: "" }
    };
    if (!L.name) return;
    LEADS.unshift(L);
logEvent('lead_created', L.name, { source: 'manual' });
saveState(); renderAll(); closeAdd();
    e.target.reset();
    var dateField = document.getElementById("add-date");
    if (dateField) dateField.value = new Date().toLocaleDateString("en-US");
    setTimeout(function(){ openLead(L.name); }, 100);
  });

  // Settings
  $("settings-btn").addEventListener("click", openSettings);
  $("settings-modal").addEventListener("click", function(e){ if (e.target.id === "settings-modal") closeSettings(); });
  $("save-goal-btn").addEventListener("click", function(){
    var v = parseFloat($("monthly-goal").value || "0");
    monthlyGoal = isNaN(v) ? 0 : v;
    localStorage.setItem(GOAL_KEY, String(monthlyGoal));
    $("settings-status").innerHTML = '<div style="color:var(--won);font-size:12px;">✓ Goal saved: ' + fmt$(monthlyGoal) + '</div>';
    renderRevenueBanner();
  });
  $("ics-export-btn").addEventListener("click", function(){
    var r = buildICS();
    if (r.count === 0) {
      $("settings-status").innerHTML = '<div style="color:var(--lost);font-size:12px;">No tasks to export. Schedule some first.</div>';
      return;
    }
    var blob = new Blob([r.ics], { type: "text/calendar" });
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    a.href = url;
    a.download = "arcascend_tasks.ics";
    a.click();
    URL.revokeObjectURL(url);
    $("settings-status").innerHTML = '<div style="color:var(--won);font-size:12px;">✓ Exported ' + r.count + ' tasks.</div>';
  });
  $("reset-btn").addEventListener("click", function(){
    if (!confirm("Reset all data? This wipes everything (leads, buckets, campaigns, settings).")) return;
    Object.keys(localStorage).filter(function(k){ return k.indexOf("arcascend") === 0; }).forEach(function(k){ localStorage.removeItem(k); });
    location.reload();
  });

  // Export all data as JSON
  $("export-data-btn").addEventListener("click", function(){
    var data = {
      version: "1.0",
      app: "ArcAscend",
      exported_at: new Date().toISOString(),
      leads: LEADS,
      buckets: BUCKETS,
      campaigns: CAMPAIGNS,
      monthlyGoal: monthlyGoal
    };
    var blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    var today = new Date().toISOString().slice(0,10);
    a.href = url;
    a.download = "arcascend-export-" + today + ".json";
    a.click();
    URL.revokeObjectURL(url);
    $("settings-status").innerHTML = '<div style="color:var(--won);font-size:12px;">✓ Exported ' + LEADS.length + ' leads + ' + BUCKETS.length + ' buckets + settings. File downloaded.</div>';
    showToast("📦 Exported " + LEADS.length + " leads to file", "success");
  });

  // Import JSON data file
  $("import-data-file").addEventListener("change", function(e){
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev){
      try {
        var parsed = JSON.parse(ev.target.result);
        if (!parsed || (parsed.app && parsed.app !== "ArcAscend")) {
          throw new Error("Not a valid ArcAscend export file");
        }
        var summary =
          "Import this file?\n\n" +
          "• " + (parsed.leads ? parsed.leads.length : 0) + " leads\n" +
          "• " + (parsed.buckets ? parsed.buckets.length : 0) + " buckets\n" +
          "• " + (parsed.campaigns ? parsed.campaigns.length : 0) + " campaigns\n" +
          "• Monthly goal: $" + (parsed.monthlyGoal || 0) + "\n\n" +
          "Exported: " + (parsed.exported_at || "unknown") + "\n\n" +
          "Choose:\n" +
          "OK = REPLACE all current data with the imported data\n" +
          "Cancel = MERGE imported leads into your existing data";
        var doReplace = confirm(summary);
        if (Array.isArray(parsed.leads)) {
          if (doReplace) {
            LEADS = parsed.leads;
          } else {
            // Merge by name+phone — new leads added, existing updated
            var existingByKey = {};
            LEADS.forEach(function(L){ existingByKey[leadKey(L)] = L; });
            var added = 0, updated = 0;
            parsed.leads.forEach(function(imported){
              var k = leadKey(imported);
              if (existingByKey[k]) {
                Object.assign(existingByKey[k], imported);
                updated++;
              } else {
                LEADS.unshift(imported);
                added++;
              }
            });
            $("settings-status").innerHTML = '<div style="color:var(--won);font-size:12px;">✓ Merged: ' + added + ' new, ' + updated + ' updated. Total leads: ' + LEADS.length + '</div>';
          }
        }
        if (doReplace && Array.isArray(parsed.buckets)) BUCKETS = parsed.buckets;
        if (doReplace && Array.isArray(parsed.campaigns)) CAMPAIGNS = parsed.campaigns;
        if (doReplace && typeof parsed.monthlyGoal === "number") {
          monthlyGoal = parsed.monthlyGoal;
          localStorage.setItem(GOAL_KEY, String(monthlyGoal));
        }
        saveState();
        saveBuckets();
        saveCampaigns();
        renderAll();
        showToast("✓ Imported successfully", "success");
        if (doReplace) {
          $("settings-status").innerHTML = '<div style="color:var(--won);font-size:12px;">✓ Replaced all data. Total leads: ' + LEADS.length + '</div>';
        }
      } catch(err) {
        $("settings-status").innerHTML = '<div style="color:var(--lost);font-size:12px;">⚠ Import failed: ' + err.message + '</div>';
        showToast("Import failed: " + err.message, "error");
      }
    };
    reader.onerror = function(){
      $("settings-status").innerHTML = '<div style="color:var(--lost);font-size:12px;">⚠ Could not read file</div>';
    };
    reader.readAsText(file);
    e.target.value = "";
  });

  // Other modals close on backdrop click
  $("modal").addEventListener("click", function(e){ if (e.target.id === "modal") closeLead(); });
  $("reach-modal").addEventListener("click", function(e){ if (e.target.id === "reach-modal") closeReach(); });
  $("campaign-modal").addEventListener("click", function(e){ if (e.target.id === "campaign-modal") closeCampaign(); });
  $("bucket-modal").addEventListener("click", function(e){ if (e.target.id === "bucket-modal") closeBk(); });

  // Bucket modal events
  ["bk-level","bk-status","bk-active","bk-goal","bk-why","bk-timeline"].forEach(function(id){
    var el = $(id);
    if (el) {
      el.addEventListener("input", updateBkPreview);
      el.addEventListener("change", updateBkPreview);
    }
  });
  $("bk-save").addEventListener("click", function(){
    var name = $("bk-name").value.trim();
    if (!name) { alert("Name required"); return; }
    var data = {
      name: name,
      icon: $("bk-icon").value.trim() || "🎯",
      desc: $("bk-desc").value.trim(),
      rule: getBkRule(),
      pinAsTab: $("bk-pin").checked
    };
    if (editingBucket) {
      var b = BUCKETS.find(function(x){ return x.id === editingBucket; });
      Object.assign(b, data);
    } else {
      BUCKETS.push(Object.assign({ id: uuid() }, data));
    }
    saveBuckets();
    closeBk();
    renderAll();
  });

  refreshFilterUI();
  renderAll();
}

// Run with error boundary
try {
  initApp();
} catch(err) {
  console.error(err);
  document.getElementById("main").innerHTML =
    '<div style="padding:40px;text-align:center;color:var(--muted);">' +
    '<div style="font-size:48px;margin-bottom:16px;">⚠️</div>' +
    '<div style="font-size:18px;color:var(--text);margin-bottom:12px;">Initialization error</div>' +
    '<div style="margin-bottom:20px;font-family:monospace;background:var(--panel-2);padding:12px;border-radius:8px;text-align:left;font-size:12px;">' + err.message + '</div>' +
    '<button onclick="localStorage.clear();location.reload();" class="btn">🔄 Clear Data &amp; Reload</button>' +
    '</div>';
}

const INTAKE_DEFAULT_QUESTIONS = [
  { id:'q_name',     label:'Full Name',                          type:'text',     required:true,  options:[] },
  { id:'q_phone',    label:'Phone Number',                       type:'tel',      required:true,  options:[] },
  { id:'q_email',    label:'Email Address',                      type:'email',    required:true,  options:[] },
  { id:'q_goal',     label:'What is your primary fitness goal?', type:'textarea', required:true,  options:[] },
  { id:'q_level',    label:'Training experience level',          type:'select',   required:true,  options:['Beginner','Intermediate','Advanced'] },
  { id:'q_timeline', label:'What is your timeline?',             type:'select',   required:false, options:['ASAP','1-3 months','3-6 months','6+ months'] },
  { id:'q_style',    label:'Preferred training style',           type:'select',   required:false, options:['1-on-1','Small group','Online','No preference'] },
  { id:'q_injuries', label:'Any injuries or limitations?',       type:'textarea', required:false, options:[] },
  { id:'q_avail',    label:'Availability (days/times)',          type:'text',     required:false, options:[] },
  { id:'q_whynow',   label:'Why are you starting now?',          type:'textarea', required:false, options:[] },
  { id:'q_outcomes', label:'Desired outcomes',                   type:'textarea', required:false, options:[] },
  { id:'q_other',    label:'Anything else we should know?',      type:'textarea', required:false, options:[] },
];

let formsSettings = {};
let formsQuestions = [];
let formsDragSrc = null;

async function formsInit() {
  if (!currentUser) return;
  var link = 'https://arcascend.app/intake.html?trainer=' + currentUser.id;
  document.getElementById('forms-link-input').value = link;
  document.getElementById('forms-open-btn').href = link;
  var qrEl = document.getElementById('forms-qr');
  qrEl.innerHTML = '';
  if (typeof QRCode !== 'undefined') new QRCode(qrEl, { text: link, width:100, height:100, colorDark:'#000', colorLight:'#fff', correctLevel: QRCode.CorrectLevel.M });
  var token = localStorage.getItem('arcascend_token');
  try {
    var res = await fetch(SUPABASE_URL + '/rest/v1/trainer_settings?user_id=eq.' + currentUser.id + '&select=*', {
      headers: { 'Authorization': 'Bearer ' + token, 'apikey': SUPABASE_KEY }
    });
    var rows = await res.json();
    var data = rows && rows[0] ? rows[0] : null;
    if (data) {
      formsSettings = data;
      document.getElementById('forms-gym-name').value   = data.gym_name || '';
      document.getElementById('forms-form-title').value = data.form_title || '';
      document.getElementById('forms-form-desc').value  = data.form_description || '';
      document.getElementById('forms-logo-url').value   = data.logo_url || '';
      document.getElementById('forms-bucket').value     = data.default_bucket || '';
      formsPreviewLogo(data.logo_url);
      formsQuestions = (data.questions && data.questions.length > 0) ? data.questions : JSON.parse(JSON.stringify(INTAKE_DEFAULT_QUESTIONS));
    } else {
      formsQuestions = JSON.parse(JSON.stringify(INTAKE_DEFAULT_QUESTIONS));
    }
  } catch(e) { formsQuestions = JSON.parse(JSON.stringify(INTAKE_DEFAULT_QUESTIONS)); }
  formsRenderQuestions();
  document.getElementById('forms-logo-url').addEventListener('input', function(e) { formsPreviewLogo(e.target.value); });
  formsInitDropZone();
}

function formsPreviewLogo(url) {
  const preview = document.getElementById('forms-logo-preview');
  const img = document.getElementById('forms-logo-img');
  if (url && (url.startsWith('http') || url.startsWith('data:'))) { img.src = url; preview.style.display = 'block'; }
  else preview.style.display = 'none';
}

var cropState = { naturalW:0, naturalH:0, scale:1, baseScale:1, x:0, y:0, dragging:false, startX:0, startY:0 };
var CROP_OUT_W = 1200, CROP_OUT_H = 300;

function formsInitDropZone() {
  var zone = document.getElementById('forms-drop-zone');
  var fileInput = document.getElementById('forms-file-input');
  if (!zone || zone.dataset.bound) return;
  zone.dataset.bound = '1';
  zone.addEventListener('click', function(){ fileInput.click(); });
  zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.style.borderColor = 'var(--accent)'; });
  zone.addEventListener('dragleave', function(){ zone.style.borderColor = 'var(--border)'; });
  zone.addEventListener('drop', function(e){
    e.preventDefault();
    zone.style.borderColor = 'var(--border)';
    if (e.dataTransfer.files && e.dataTransfer.files[0]) formsHandleImageFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', function(e){
    if (e.target.files && e.target.files[0]) formsHandleImageFile(e.target.files[0]);
  });
}

function formsHandleImageFile(file) {
  if (!file.type.startsWith('image/')) { alert('Please choose an image file.'); return; }
  var reader = new FileReader();
  reader.onload = function(e) { formsOpenCropModal(e.target.result); };
  reader.readAsDataURL(file);
}

function formsOpenCropModal(dataUrl) {
  var modal = document.getElementById('crop-modal');
  var img = document.getElementById('crop-image');
  img.onload = function() {
    cropState.naturalW = img.naturalWidth;
    cropState.naturalH = img.naturalHeight;
    var viewport = document.getElementById('crop-viewport');
    var vw = viewport.clientWidth, vh = viewport.clientHeight;
    cropState.baseScale = Math.max(vw / cropState.naturalW, vh / cropState.naturalH);
    cropState.scale = cropState.baseScale;
    cropState.x = (vw - cropState.naturalW * cropState.scale) / 2;
    cropState.y = (vh - cropState.naturalH * cropState.scale) / 2;
    document.getElementById('crop-zoom').value = 100;
    formsRenderCrop();
  };
  img.src = dataUrl;
  modal.classList.add('show');
}

function formsRenderCrop() {
  var img = document.getElementById('crop-image');
  img.style.width = (cropState.naturalW * cropState.scale) + 'px';
  img.style.height = (cropState.naturalH * cropState.scale) + 'px';
  img.style.transform = 'translate(' + cropState.x + 'px,' + cropState.y + 'px)';
}

function formsCloseCropModal() {
  document.getElementById('crop-modal').classList.remove('show');
}

function formsApplyCrop() {
  var canvas = document.createElement('canvas');
  canvas.width = CROP_OUT_W;
  canvas.height = CROP_OUT_H;
  var ctx = canvas.getContext('2d');
  var viewport = document.getElementById('crop-viewport');
  var vw = viewport.clientWidth, vh = viewport.clientHeight;
  var ratio = CROP_OUT_W / vw;
  var img = document.getElementById('crop-image');
  ctx.drawImage(img,
    -cropState.x / cropState.scale, -cropState.y / cropState.scale,
    vw / cropState.scale, vh / cropState.scale,
    0, 0, CROP_OUT_W, CROP_OUT_H
  );
  var dataUrl = canvas.toDataURL('image/jpeg', 0.85);
  document.getElementById('forms-logo-url').value = dataUrl;
  formsPreviewLogo(dataUrl);
  formsCloseCropModal();
}

(function(){
  var viewport;
  document.addEventListener('mousedown', function(e){
    viewport = document.getElementById('crop-viewport');
    if (!viewport || !viewport.contains(e.target)) return;
    cropState.dragging = true;
    cropState.startX = e.clientX - cropState.x;
    cropState.startY = e.clientY - cropState.y;
    viewport.style.cursor = 'grabbing';
  });
  document.addEventListener('mousemove', function(e){
    if (!cropState.dragging) return;
    var vp = document.getElementById('crop-viewport');
    var vw = vp.clientWidth, vh = vp.clientHeight;
    var imgW = cropState.naturalW * cropState.scale;
    var imgH = cropState.naturalH * cropState.scale;
    var newX = e.clientX - cropState.startX;
    var newY = e.clientY - cropState.startY;
    cropState.x = Math.min(0, Math.max(newX, vw - imgW));
    cropState.y = Math.min(0, Math.max(newY, vh - imgH));
    formsRenderCrop();
  });
  document.addEventListener('mouseup', function(){
    cropState.dragging = false;
    if (viewport) viewport.style.cursor = 'grab';
  });
  document.addEventListener('input', function(e){
    if (e.target.id !== 'crop-zoom') return;
    var vp = document.getElementById('crop-viewport');
    var vw = vp.clientWidth, vh = vp.clientHeight;
    var cx = vw/2, cy = vh/2;
    var imgCx = (cx - cropState.x) / cropState.scale;
    var imgCy = (cy - cropState.y) / cropState.scale;
    var pct = e.target.value / 100;
    cropState.scale = cropState.baseScale * pct;
    cropState.x = cx - imgCx * cropState.scale;
    cropState.y = cy - imgCy * cropState.scale;
    var imgW2 = cropState.naturalW * cropState.scale;
    var imgH2 = cropState.naturalH * cropState.scale;
    cropState.x = Math.min(0, Math.max(cropState.x, vw - imgW2));
    cropState.y = Math.min(0, Math.max(cropState.y, vh - imgH2));
    formsRenderCrop();
  });
})();


function autoBackupReminder() {
  // Remind trainer to export data weekly
  var lastBackup = localStorage.getItem('arcascend_last_backup');
  var now = Date.now();
  if (!lastBackup || (now - parseInt(lastBackup)) > 7 * 24 * 60 * 60 * 1000) {
    var reminder = document.createElement('div');
    reminder.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#f59e0b;color:#000;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:9999;cursor:pointer;';
    reminder.textContent = '⚠️ Weekly reminder: Export your data backup (Settings → Export All Data)';
    reminder.onclick = function() { 
      localStorage.setItem('arcascend_last_backup', Date.now().toString());
      reminder.remove(); 
    };
    document.body.appendChild(reminder);
  }
}

function formsCopyLink() {
  navigator.clipboard.writeText(document.getElementById('forms-link-input').value).then(function() {
    var btn = document.getElementById('forms-copy-btn');
    btn.textContent = 'Copied!';
    setTimeout(function() { btn.textContent = 'Copy Link'; }, 1800);
  });
}

function formsRenderQuestions() {
  const list = document.getElementById('forms-questions-list');
  list.innerHTML = '';
  formsQuestions.forEach(function(q, i) {
    const row = document.createElement('div');
    row.draggable = true;
    row.dataset.idx = i;
    row.style.cssText = 'background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;padding:14px;display:grid;grid-template-columns:24px 1fr auto;gap:10px;align-items:start;cursor:grab;transition:opacity .15s';
    const typeOpts = ['text','textarea','tel','email','number','select','multiselect'].map(function(t) { return '<option value="'+t+'"'+(q.type===t?' selected':'')+'>'+t+'</option>'; }).join('');
    const showOpts = ['select','multiselect'].indexOf(q.type) > -1;
    row.innerHTML = '<div style="padding-top:2px;color:var(--text-muted);user-select:none;font-size:18px;line-height:1">&#8995;</div>'
      + '<div style="display:flex;flex-direction:column;gap:8px">'
      + '<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">'
      + '<input class="forms-q-label" data-idx="'+i+'" value="'+q.label.replace(/"/g,"&quot;")+'" placeholder="Question label" style="flex:1;min-width:160px;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:7px 10px;color:var(--text-primary);font-size:13px" />'
      + '<select class="forms-q-type" data-idx="'+i+'" style="background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:7px 8px;color:var(--text-primary);font-size:13px">'+typeOpts+'</select>'
      + '<label style="display:flex;align-items:center;gap:5px;font-size:12px;color:var(--text-muted);white-space:nowrap;cursor:pointer"><input type="checkbox" class="forms-q-required" data-idx="'+i+'" '+(q.required?'checked':'')+' style="accent-color:var(--accent)"> Required</label>'
      + '</div>'
      + '<div class="forms-q-options-wrap" style="display:'+(showOpts?'block':'none')+'">'
      + '<div style="font-size:12px;color:var(--text-muted);margin-bottom:4px">Options (one per line):</div>'
      + '<textarea class="forms-q-options" data-idx="'+i+'" rows="3" style="width:100%;background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:7px 10px;color:var(--text-primary);font-size:12px;resize:vertical;box-sizing:border-box">'+(q.options||[]).join('\n')+'</textarea>'
      + '</div></div>'
      + '<button onclick="formsDeleteQuestion('+i+')" style="padding:4px 8px;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--text-muted);font-size:16px;cursor:pointer;line-height:1">x</button>';
    row.querySelector('.forms-q-label').addEventListener('input', function(e) { formsQuestions[+e.target.dataset.idx].label = e.target.value; });
    row.querySelector('.forms-q-type').addEventListener('change', function(e) {
      var idx = +e.target.dataset.idx;
      formsQuestions[idx].type = e.target.value;
      row.querySelector('.forms-q-options-wrap').style.display = ['select','multiselect'].indexOf(e.target.value) > -1 ? 'block' : 'none';
    });
    row.querySelector('.forms-q-required').addEventListener('change', function(e) { formsQuestions[+e.target.dataset.idx].required = e.target.checked; });
    var optTA = row.querySelector('.forms-q-options');
    if (optTA) optTA.addEventListener('input', function(e) { formsQuestions[+e.target.dataset.idx].options = e.target.value.split('\n').map(function(s){return s.trim();}).filter(Boolean); });
    row.addEventListener('dragstart', function(e) { formsDragSrc=i; e.dataTransfer.effectAllowed='move'; setTimeout(function(){row.style.opacity='0.4';},0); });
    row.addEventListener('dragend', function() { row.style.opacity='1'; formsDragSrc=null; });
    row.addEventListener('dragover', function(e) { e.preventDefault(); e.dataTransfer.dropEffect='move'; });
    row.addEventListener('drop', function(e) { e.preventDefault(); if(formsDragSrc===null||formsDragSrc===i)return; var moved=formsQuestions.splice(formsDragSrc,1)[0]; formsQuestions.splice(i,0,moved); formsRenderQuestions(); });
    list.appendChild(row);
  });
}

function formsAddQuestion() {
  formsQuestions.push({ id:'q_'+Date.now(), label:'', type:'text', required:false, options:[] });
  formsRenderQuestions();
  var last = document.getElementById('forms-questions-list').lastElementChild;
  if (last) last.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function formsDeleteQuestion(idx) {
  if (formsQuestions.length <= 1) return;
  formsQuestions.splice(idx, 1);
  formsRenderQuestions();
}

function formsResetQuestions() {
  if (!confirm('Reset all questions to defaults?')) return;
  formsQuestions = JSON.parse(JSON.stringify(INTAKE_DEFAULT_QUESTIONS));
  formsRenderQuestions();
}

async function formsSaveSettings() {
  if (!currentUser) return;
  var statusEl = document.getElementById('forms-save-status');
  statusEl.textContent = 'Saving...';
  var token = localStorage.getItem('arcascend_token');
  var payload = {
    user_id: currentUser.id,
    gym_name: document.getElementById('forms-gym-name').value.trim(),
    form_title: document.getElementById('forms-form-title').value.trim(),
    form_description: document.getElementById('forms-form-desc').value.trim(),
    logo_url: document.getElementById('forms-logo-url').value.trim(),
    default_bucket: document.getElementById('forms-bucket').value.trim() || null,
    questions: formsQuestions,
  };
  try {
    var res = await fetch(SUPABASE_URL + '/rest/v1/trainer_settings?on_conflict=user_id', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + token,
        'apikey': SUPABASE_KEY,
        'Content-Type': 'application/json',
        'Prefer': 'resolution=merge-duplicates'
      },
      body: JSON.stringify(payload)
    });
    if (res.ok || res.status === 201 || res.status === 204) {
      statusEl.textContent = '✓ Saved';
      statusEl.style.color = '#22c55e';
      statusEl.style.fontWeight = '600';
      var qStatus = document.getElementById('forms-q-save-status');
      if (qStatus) { qStatus.textContent = '✓ Saved'; qStatus.style.color = '#22c55e'; qStatus.style.fontWeight = '600'; }
      setTimeout(function(){
        statusEl.textContent = '';
        statusEl.style.color = '';
        statusEl.style.fontWeight = '';
        if (qStatus) { qStatus.textContent = ''; qStatus.style.color = ''; qStatus.style.fontWeight = ''; }
      }, 2500);
    } else {
      var err = await res.text();
      statusEl.textContent = 'Error: ' + err;
    }
  } catch(e) {
    statusEl.textContent = 'Error: ' + e.message;
  }
}

</script>




<div class="modal-bg" id="crop-modal">
  <div class="modal" style="max-width:640px">
    <div class="modal-head">
      <div class="modal-title">Position Your Header Image</div>
      <button class="modal-close" onclick="formsCloseCropModal()">x</button>
    </div>
    <div class="modal-body">
      <div id="crop-viewport" style="width:100%;height:160px;overflow:hidden;position:relative;border-radius:10px;border:1px solid var(--border);cursor:grab;background:#000">
        <img id="crop-image" style="position:absolute;left:0;top:0;max-width:none;user-select:none;-webkit-user-drag:none" draggable="false" />
      </div>
      <div style="margin-top:14px;display:flex;align-items:center;gap:10px">
        <span style="font-size:12px;color:var(--text-muted)">Zoom</span>
        <input type="range" id="crop-zoom" min="100" max="300" value="100" style="flex:1" />
      </div>
      <div class="form-actions" style="margin-top:18px">
        <button type="button" class="btn btn-ghost" onclick="formsCloseCropModal()">Cancel</button>
        <button type="button" class="btn-add" onclick="formsApplyCrop()">Apply</button>
      </div>
    </div>
  </div>
</div>

<script src="active-board.js"></script>
</body>
</html>

