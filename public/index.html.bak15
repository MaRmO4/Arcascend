// ==========================================================
// BUCKET MODAL
// ==========================================================
var editingBucket = null;
function openBk(id) {
  editingBucket = id || null;
  var b = id ? BUCKETS.find(function(x){ return x.id === id; }) : null;
  $("bk-title").textContent = b ? "Edit Bucket" : "Create Bucket";
  $("bk-name").value = b ? b.name : "";
  $("bk-icon").value = b ? b.icon : "🎯";
  $("bk-desc").value = b ? (b.desc||"") : "";
  var r = b ? (b.rule||{}) : {};
  $("bk-level").value = r.level || "";
  $("bk-status").value = r.status || "";
  $("bk-active").value = r.active || "";
  $("bk-goal").value = r.goal || "";
  $("bk-why").value = r.why || "";
  $("bk-timeline").value = r.timeline || "";
  $("bk-pin").checked = b ? !!b.pinAsTab : false;
  updateBkPreview();
  $("bucket-modal").classList.add("show");
}
function closeBk() { $("bucket-modal").classList.remove("show"); }
function getBkRule() {
  var r = {};
  if ($("bk-level").value) r.level = $("bk-level").value;
  if ($("bk-status").value) r.status = $("bk-status").value;
  if ($("bk-active").value) r.active = $("bk-active").value;
  if ($("bk-goal").value) r.goal = $("bk-goal").value;
  if ($("bk-why").value) r.why = $("bk-why").value;
  if ($("bk-timeline").value) r.timeline = $("bk-timeline").value;
  return r;
}
function updateBkPreview() {
  $("bk-preview").textContent = leadsInBucket({ rule: getBkRule() }).length;
}

