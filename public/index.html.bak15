// ==========================================
var UNDO_STACK = [];
var UNDO_PREV_SNAPSHOT = null;
function pushUndoSnapshot() {
  if (UNDO_PREV_SNAPSHOT !== null) {
    UNDO_STACK.push(UNDO_PREV_SNAPSHOT);
    if (UNDO_STACK.length > 20) UNDO_STACK.shift();
  }
  var btn = document.getElementById("undo-btn");
  if (btn) btn.style.opacity = UNDO_STACK.length > 0 ? "1" : "0.5";
}
function performUndo() {
  if (UNDO_STACK.length === 0) { return; }
  var restored = UNDO_STACK.pop();
  LEADS = JSON.parse(restored);
  UNDO_PREV_SNAPSHOT = restored;
  localStorage.setItem(STORAGE_KEY, JSON.stringify(LEADS));
  saveToSupabase();
  renderAll();
  var btn = document.getElementById("undo-btn");
  if (btn) btn.style.opacity = UNDO_STACK.length > 0 ? "1" : "0.5";
  var ind = document.getElementById("last-saved-text");
  if (ind) ind.textContent = "Undid last change";
}
document.addEventListener("keydown", function(e) {
  if ((e.metaKey || e.ctrlKey) && e.key === "z") {
    e.preventDefault();
    performUndo();
  }
});
var _origRenderAllForUndo = renderAll;
renderAll = function() {
  _origRenderAllForUndo.apply(this, arguments);
  UNDO_PREV_SNAPSHOT = JSON.stringify(LEADS);
};

function saveState() {
  pushUndoSnapshot();
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(LEADS));
    saveToSupabase();
    lastSavedAt = Date.now();
    localStorage.setItem(LAST_SAVED_KEY, String(lastSavedAt));
    updateSavedIndicator();
  } catch(e) {
    var el = $("save-indicator");
    if (el) {
      el.classList.add("unsaved");
      $("last-saved-text").textContent = "⚠ Save failed: " + e.message;
    }
  }
  if (typeof currentTab !== 'undefined' && currentTab === 'home') renderHomeTab();
}

function updateSavedIndicator() {
  var el = $("last-saved-text");
  if (!el) return;
  if (!lastSavedAt) {
    el.textContent = "All changes saved";
    return;
  }
  var diff = Math.floor((Date.now() - lastSavedAt) / 1000);
  var msg;
  if (diff < 5) msg = "✓ Just saved";
  else if (diff < 60) msg = "Saved " + diff + "s ago";
  else if (diff < 3600) msg = "Saved " + Math.floor(diff/60) + " min ago";
  else if (diff < 86400) msg = "Saved " + Math.floor(diff/3600) + "h ago";
  else msg = "Saved " + new Date(lastSavedAt).toLocaleString();
  el.textContent = msg;
  var indicator = $("save-indicator");
  if (indicator) indicator.classList.remove("unsaved");
}

// Live update of the timestamp every 10 seconds
setInterval(updateSavedIndicator, 10000);
function loadState() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      var parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) LEADS = parsed;
    }
  } catch(e) {}
}
