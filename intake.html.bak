
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Client Intake Form</title>
<style>
  :root {
    --bg:#0f1117; --panel:#1a1d27; --panel2:#222634; --border:#2c3142;
    --text:#e8eaed; --muted:#9aa0ac; --accent:#3b82f6; --won:#22c55e;
  }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { background:var(--bg); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif; line-height:1.5; padding:0 0 60px; }
  .header-img { width:100%; height:160px; object-fit:cover; display:block; background:var(--panel2); }
  .container { max-width:640px; margin:0 auto; padding:0 20px; }
  .form-head { background:var(--panel); border-radius:0 0 16px 16px; padding:28px 24px; margin-bottom:20px; border:1px solid var(--border); border-top:none; }
  .form-title { font-size:26px; font-weight:700; margin-bottom:12px; }
  .form-desc { font-size:14px; color:var(--muted); }
  .field { background:var(--panel); border-radius:12px; padding:20px; margin-bottom:14px; border:1px solid var(--border); }
  .field label { display:block; font-size:15px; font-weight:600; margin-bottom:12px; }
  .req { color:var(--accent); margin-left:3px; }
  input[type=text], input[type=tel], input[type=email], select, textarea {
    width:100%; background:var(--panel2); border:1px solid var(--border); border-radius:8px;
    padding:11px 13px; color:var(--text); font-size:14px; font-family:inherit;
  }
  textarea { min-height:80px; resize:vertical; }
  input:focus, select:focus, textarea:focus { outline:none; border-color:var(--accent); }
  .opt { display:flex; align-items:center; gap:10px; padding:9px 0; cursor:pointer; font-size:14px; font-weight:400; }
  .opt input { width:auto; cursor:pointer; }
  .submit-btn { width:100%; background:var(--accent); color:#fff; border:none; border-radius:10px; padding:15px; font-size:16px; font-weight:700; cursor:pointer; margin-top:8px; transition:opacity 0.15s; }
  .submit-btn:hover { opacity:0.9; }
  .submit-btn:disabled { opacity:0.5; cursor:not-allowed; }
  .success { text-align:center; padding:60px 24px; }
  .success-icon { font-size:56px; margin-bottom:16px; }
  .success h2 { font-size:24px; margin-bottom:10px; }
  .success p { color:var(--muted); }
  .err { color:#ef4444; font-size:13px; margin-top:8px; display:none; }
  .brand { text-align:center; font-size:12px; color:var(--muted); margin-top:24px; }
</style>
</head>
<body>
<img class="header-img" id="header-img" src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200&h=320&fit=crop" alt="">
<div class="container">
  <div id="form-wrap">
    <div class="form-head">
      <div class="form-title" id="form-title">Client Intake Form</div>
      <div class="form-desc" id="form-desc">This form helps me understand your current fitness level, lifestyle, and goals so I can tailor our consultation. Please answer as openly and honestly as you can — this is all about you.</div>
    </div>

    <div id="dynamic-fields"></div>
    <button class="submit-btn" id="submit-btn" onclick="submitForm()">Submit & Get Started</button>
    <div class="err" id="err"></div>
    <div class="brand">Powered by ArcAscend</div>
  </div>

  <div id="success-wrap" class="success" style="display:none;">
    <div class="success-icon">✅</div>
    <h2>Thank you!</h2>
    <p>Your information has been received. We'll be in touch with you soon.</p>
  </div>
</div>

<script>
var SUPABASE_URL = 'https://udzfpeztwgsynjhwjwic.supabase.co';
var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVkemZwZXp0d2dzeW5qaHdqd2ljIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk2OTcwOTcsImV4cCI6MjA5NTI3MzA5N30.Eke_HxZtww3zVekkPMDydT90NkVWSltJjA2fr40oquQ';
var params = new URLSearchParams(window.location.search);
var TRAINER_ID = params.get('trainer') || 'a83ab75d-0b97-4729-9cf6-7630c2c03115';
var FALLBACK_QUESTIONS = [
  { id:'q_name', label:'Full Name', type:'text', required:true, options:[] },
  { id:'q_phone', label:'Phone Number', type:'tel', required:true, options:[] },
  { id:'q_email', label:'Email Address', type:'email', required:false, options:[] },
  { id:'q_goal', label:'What is your primary fitness goal?', type:'textarea', required:true, options:[] },
  { id:'q_level', label:'Training experience level', type:'select', required:true, options:['Beginner','Intermediate','Advanced'] },
  { id:'q_timeline', label:'What is your timeline?', type:'select', required:false, options:['ASAP','1-3 months','3-6 months','6+ months'] },
  { id:'q_style', label:'Preferred training style', type:'select', required:false, options:['1-on-1','Small group','Online','No preference'] },
  { id:'q_injuries', label:'Any injuries or limitations?', type:'textarea', required:false, options:[] },
  { id:'q_avail', label:'Availability (days/times)', type:'text', required:false, options:[] },
  { id:'q_whynow', label:'Why are you starting now?', type:'textarea', required:false, options:[] },
  { id:'q_outcomes', label:'Desired outcomes', type:'textarea', required:false, options:[] },
  { id:'q_other', label:'Anything else we should know?', type:'textarea', required:false, options:[] }
];
var loadedQuestions = [];
var loadedBucket = '';

async function loadForm() {
  try {
    var res = await fetch(SUPABASE_URL + '/rest/v1/trainer_settings?user_id=eq.' + TRAINER_ID + '&select=gym_name,form_title,form_description,logo_url,questions,default_bucket', {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY }
    });
    var rows = await res.json();
    var s = rows && rows[0] ? rows[0] : {};
    if (s.form_title) { document.getElementById('form-title').textContent = s.form_title; document.title = s.form_title; }
    if (s.form_description) document.getElementById('form-desc').textContent = s.form_description;
    if (s.logo_url) { var img = document.getElementById('header-img'); img.src = s.logo_url; img.style.objectFit = 'contain'; img.style.background = '#111'; img.style.maxHeight = '200px'; }
    loadedBucket = s.default_bucket || '';
    loadedQuestions = (s.questions && s.questions.length > 0) ? s.questions : FALLBACK_QUESTIONS;
  } catch(e) { loadedQuestions = FALLBACK_QUESTIONS; }
  renderFields();
}

function renderFields() {
  var c = document.getElementById('dynamic-fields');
  c.innerHTML = loadedQuestions.map(function(q) {
    var req = q.required ? '<span class="req">*</span>' : '';
    var f = '';
    if (q.type === 'textarea') {
      f = '<textarea id="' + q.id + '" name="' + q.id + '"' + (q.required ? ' required' : '') + '></textarea>';
    } else if (q.type === 'select') {
      var opts = '<option value="">Choose</option>' + (q.options||[]).map(function(o){ return '<option value="' + o + '">' + o + '</option>'; }).join('');
      f = '<select id="' + q.id + '" name="' + q.id + '"' + (q.required ? ' required' : '') + '>' + opts + '</select>';
    } else if (q.type === 'multiselect') {
      f = '<div>' + (q.options||[]).map(function(o){ return '<label class="opt"><input type="checkbox" name="' + q.id + '" value="' + o + '"> ' + o + '</label>'; }).join('') + '</div>';
    } else {
      f = '<input type="' + q.type + '" id="' + q.id + '" name="' + q.id + '"' + (q.required ? ' required' : '') + '>';
    }
    return '<div class="field"><label>' + q.label + req + '</label>' + f + '</div>';
  }).join('');
}

function submitForm() {
  var btn = document.getElementById('submit-btn');
  var fields = {};
  loadedQuestions.forEach(function(q) {
    if (q.type === 'multiselect') {
      fields[q.id] = Array.from(document.querySelectorAll('input[name="' + q.id + '"]:checked')).map(function(c){ return c.value; }).join(', ');
    } else {
      var el = document.getElementById(q.id);
      fields[q.id] = el ? el.value : '';
    }
  });
  var missing = loadedQuestions.filter(function(q){ return q.required && !fields[q.id]; });
  if (missing.length > 0) { alert('Please fill in: ' + missing.map(function(q){ return q.label; }).join(', ')); return; }
  var fullName = fields['q_name'] || '';
  var phoneVal = fields['q_phone'] || '';
  var emailVal = fields['q_email'] || '';
  var goalVal = fields['q_goal'] || '';
  var dataObj = Object.assign({}, fields, {
    name: fullName,
    phone: phoneVal,
    email: emailVal,
    goal: goalVal,
    source: 'Intake Form',
    bucket: loadedBucket,
    submittedAt: new Date().toISOString(),
    tasks: [],
    billing: { active: false, sessions: 0, rate: 0, package: '', paid: false }
  });
  var lead = {
    user_id: TRAINER_ID,
    name: fullName,
    phone: phoneVal,
    email: emailVal,
    goal: goalVal,
    status: 'New',
    data: JSON.stringify(dataObj)
  };
  btn.disabled = true; btn.textContent = 'Submitting...';
  fetch(SUPABASE_URL + '/rest/v1/leads', {
    method: 'POST',
    headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
    body: JSON.stringify(lead)
  }).then(function(resp) {
    if (resp.ok || resp.status === 201) {
      document.getElementById('form-wrap').innerHTML = '<div class="success"><div class="success-icon">✅</div><h2>You\'re all set!</h2><p>We\'ll be in touch with you shortly.</p></div>';
    } else { btn.disabled = false; btn.textContent = 'Submit & Get Started'; alert('Something went wrong. Please try again.'); }
  }).catch(function(e) { btn.disabled = false; btn.textContent = 'Submit & Get Started'; alert('Error: ' + e.message); });
}

loadForm();
</script>

</body>
</html>